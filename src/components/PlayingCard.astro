---
import { getSuitSymbol } from '../lib/card-format';

interface Props {
	value: string;
	suit: 'hearts' | 'diamonds' | 'clubs' | 'spades';
	faceDown?: boolean;
}

const { value, suit, faceDown = false } = Astro.props;

const suitColors = {
	hearts: 'text-red-600',
	diamonds: 'text-red-600',
	clubs: 'text-gray-900',
	spades: 'text-gray-900',
};

const suitSymbol = getSuitSymbol(suit);
---

<div class="playing-card w-20 h-28 flex items-center justify-center">
	{
		faceDown ? (
			<div class="card-back-deco absolute inset-1 rounded" />
		) : (
			<div class="w-full h-full p-2 flex flex-col">
				<div class={`text-xl font-bold ${suitColors[suit]}`}>{value}</div>
				<div class={`flex-1 flex items-center justify-center text-4xl ${suitColors[suit]}`}>
					{suitSymbol}
				</div>
				<div class={`text-xl font-bold text-right ${suitColors[suit]} rotate-180`}>{value}</div>
			</div>
		)
	}
</div>
