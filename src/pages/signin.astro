---
import CasinoLayout from '../layouts/casino.astro';
import DecoDivider from '../components/DecoDivider.astro';
import DecoIcon from '../components/DecoIcon.astro';

const url = new URL(Astro.request.url);
const hasAuthError = url.searchParams.has('error') || url.searchParams.has('error_description');
---

<CasinoLayout title="Sign In - Arcturus Casino">
	<div
		class="deco-atmosphere deco-grain flex min-h-[80vh] items-center justify-center px-4 py-16 sm:px-6 lg:px-8"
	>
		<div class="w-full max-w-md">
			<div class="deco-panel deco-frame p-10">
				<div class="mb-8 text-center">
					<div
						class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-sm border"
						style="border-color: var(--deco-brass); color: var(--deco-brass)"
					>
						<DecoIcon name="star" size={28} />
					</div>
					<p class="deco-section-eyebrow mb-3">Members' Entrance</p>
					<h2 class="deco-display text-3xl">Welcome to <em>Arcturus</em></h2>
					<div class="mx-auto my-5 max-w-[10rem]">
						<DecoDivider />
					</div>
					<p class="deco-body-text text-sm">
						Continue with Google to play with your virtual chip balance.
					</p>
				</div>

				{
					// Always rendered so the client-side sign-in handler can reveal it
					// on a popup-blocked / network / unexpected error (the server-side
					// `error`/`error_description` query params only cover some paths).
				}
				<div
					id="signin-error"
					class:list={[
						'mb-4 rounded-sm border border-[var(--deco-oxblood-bright)]/40 bg-[var(--deco-oxblood)]/15 p-4 text-sm',
						!hasAuthError && 'hidden',
					]}
					style="color: var(--deco-rose)"
				>
					Google sign-in did not complete. Please try again.
				</div>

				<button
					type="button"
					id="google-signin"
					class="flex w-full items-center justify-center gap-3 rounded-sm py-4 text-lg font-semibold transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[var(--deco-brass)] focus:ring-offset-2"
					style="background: var(--deco-ivory); color: var(--deco-obsidian)"
				>
					<span class="font-display text-xl font-bold">G</span>
					<span>Continue with Google</span>
				</button>
			</div>

			<div class="mt-6 text-center">
				<a href="/" class="deco-link">&larr; Back to Home</a>
			</div>
		</div>
	</div>
</CasinoLayout>

<script>
	import { authClient } from '../lib/auth-client';

	const googleButton = document.getElementById('google-signin') as HTMLButtonElement | null;
	googleButton?.addEventListener('click', async () => {
		googleButton.disabled = true;
		try {
			await authClient.signIn.social({
				provider: 'google',
				callbackURL: '/',
				errorCallbackURL: '/signin',
			});
		} catch (error) {
			console.error('Google sign-in error:', error);
			document.getElementById('signin-error')?.classList.remove('hidden');
			googleButton.disabled = false;
		}
	});
</script>
