---
import CasinoLayout from '../../layouts/casino.astro';
import PokerChip from '../../components/PokerChip.astro';
import { createPublicGameSession } from '../../lib/public-game-session';
import { WHEEL_ORDER, RED_NUMBERS, CHIP_DENOMINATIONS } from '../../lib/roulette/constants';

const user = Astro.locals.user;
const gameSession = createPublicGameSession(user);
const initialBalance = gameSession.initialBalance;
const clientUserId = gameSession.clientUserId;

// ─── Wheel SVG generation ───────────────────────────────────────────────────
const SEGMENT_DEG = 360 / 37;
const WCX = 100;
const WCY = 100;
const WR = 98;
const WLR = 76;

function polarToCartesian(cx: number, cy: number, r: number, angleDeg: number) {
	const rad = ((angleDeg - 90) * Math.PI) / 180;
	return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
}

function arcPath(startAngle: number, endAngle: number) {
	const start = polarToCartesian(WCX, WCY, WR, startAngle);
	const end = polarToCartesian(WCX, WCY, WR, endAngle);
	const largeArc = endAngle - startAngle > 180 ? 1 : 0;
	return `M ${WCX} ${WCY} L ${start.x.toFixed(2)} ${start.y.toFixed(2)} A ${WR} ${WR} 0 ${largeArc} 1 ${end.x.toFixed(2)} ${end.y.toFixed(2)} Z`;
}

const wheelSegments = WHEEL_ORDER.map((num, i) => {
	const center = i * SEGMENT_DEG;
	const start = center - SEGMENT_DEG / 2;
	const end = center + SEGMENT_DEG / 2;
	const label = polarToCartesian(WCX, WCY, WLR, center);
	const fill = num === 0 ? '#0a7a3a' : RED_NUMBERS.has(num) ? '#b91c1c' : '#171717';
	return {
		num,
		path: arcPath(start, end),
		lx: label.x.toFixed(2),
		ly: label.y.toFixed(2),
		fill,
	};
});

// ─── Betting table number grid ──────────────────────────────────────────────
// Row 0 (top): 3, 6, 9, ... 36  | Column index 0 (n % 3 === 0)
// Row 1 (mid): 2, 5, 8, ... 35  | Column index 1 (n % 3 === 2)
// Row 2 (bot): 1, 4, 7, ... 34  | Column index 2 (n % 3 === 1)
const numberRows: number[][] = [0, 1, 2].map((row) =>
	Array.from({ length: 12 }, (_, col) => col * 3 + (3 - row)),
);
const flatNumbers = numberRows.flat();

const pocketBg = (n: number): string => (RED_NUMBERS.has(n) ? '#b91c1c' : '#171717');

const chipColors: Array<'red' | 'blue' | 'green' | 'gold' | 'black'> = [
	'red',
	'blue',
	'green',
	'gold',
	'black',
	'gold',
];
---

<CasinoLayout title="Roulette - Arcturus Casino">
	<div
		id="roulette-root"
		data-testid="roulette-root"
		data-user-id={clientUserId}
		data-guest-mode={gameSession.guestModeValue}
		data-initial-balance={initialBalance}
		class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
	>
		<!-- Header -->
		<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
			<div>
				<a
					href="/games"
					class="text-[var(--deco-muted)] hover:text-[var(--deco-brass)] transition-colors mb-2 inline-block"
				>
					← Back to Games
				</a>
				<h1 class="deco-section-title text-4xl">Roulette</h1>
				<p class="text-[var(--deco-muted)] text-sm mt-1">
					European single-zero · 100% free virtual chips.
				</p>
			</div>
			<div
				class="bg-[var(--deco-obsidian-2)] px-6 py-3 rounded-lg border border-[var(--deco-brass-dim)]"
			>
				<div class="text-xs text-[var(--deco-muted)] mb-1">{gameSession.balanceLabel}</div>
				<div
					class="text-2xl font-bold text-[var(--deco-brass)]"
					id="chip-balance"
					data-testid="chip-balance"
				>
					{'$' + initialBalance.toLocaleString()}
				</div>
			</div>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
			<!-- Main Game Area (3 cols) -->
			<div class="lg:col-span-3 space-y-4">
				<!-- Wheel + Status Panel -->
				<div
					class="bg-[var(--deco-obsidian-2)] rounded-xl border border-[var(--deco-line)] p-4 flex flex-col sm:flex-row items-center gap-6"
				>
					<!-- Wheel -->
					<div class="wheel-container relative shrink-0">
						<div id="roulette-wheel" class="roulette-wheel-inner">
							<svg viewBox="0 0 200 200" class="w-full h-full" aria-hidden="true">
								{
									wheelSegments.map((seg) => (
										<g>
											<path d={seg.path} fill={seg.fill} stroke="#3f3f46" stroke-width="0.3" />
											<text
												x={seg.lx}
												y={seg.ly}
												fill="white"
												font-size="6"
												font-weight="bold"
												text-anchor="middle"
												dominant-baseline="central"
											>
												{seg.num}
											</text>
										</g>
									))
								}
								<circle cx="100" cy="100" r="30" fill="#1a1a2e" stroke="#d4a843" stroke-width="1"
								></circle>
								<circle cx="100" cy="100" r="6" fill="#d4a843"></circle>
							</svg>
						</div>
						<div class="wheel-pointer" aria-hidden="true">▼</div>
					</div>

					<!-- Result + Status -->
					<div class="flex-1 w-full">
						<div class="flex items-center gap-3 mb-2">
							<span
								id="game-phase"
								class="px-2 py-0.5 rounded text-xs font-bold bg-[var(--deco-obsidian-3)] text-[var(--deco-brass)] uppercase tracking-wider"
							>
								Place Your Bets
							</span>
						</div>
						<div class="flex items-baseline gap-4 mb-2">
							<div>
								<div class="text-[var(--deco-muted)] text-xs uppercase tracking-wider">
									Winning Number
								</div>
								<div
									id="wheel-result"
									data-testid="wheel-result"
									aria-live="polite"
									class="text-3xl font-bold text-[var(--deco-ivory)]"
								>
									—
								</div>
							</div>
							<div>
								<div class="text-[var(--deco-muted)] text-xs uppercase tracking-wider">Net</div>
								<div
									id="net-delta"
									data-testid="net-delta"
									aria-live="polite"
									class="text-2xl font-bold text-[var(--deco-muted)]"
								>
									0
								</div>
							</div>
						</div>
						<div id="game-message" class="text-[var(--deco-ivory-dim)] text-sm min-h-[20px]">
							Select a chip, place your bets, then spin!
						</div>
						<div
							id="bet-results"
							data-testid="bet-results"
							aria-live="polite"
							class="mt-2 space-y-0.5"
						>
						</div>
					</div>
				</div>

				<!-- Betting Table -->
				<div class="roulette-table rounded-2xl p-3 sm:p-4 space-y-1">
					<!-- Number grid: 0 | 1-36 | column bets -->
					<div class="flex gap-1 items-stretch">
						<!-- Zero -->
						<div
							data-bet-type="straight"
							data-bet-target="0"
							role="button"
							tabindex="0"
							class="bet-cell rounded-l-lg flex items-center justify-center text-white font-bold text-lg px-2"
							style="background-color: #0a7a3a; min-height: 120px;"
						>
							0
						</div>

						<!-- 3×12 number grid -->
						<div class="grid grid-cols-12 grid-rows-3 gap-0.5 flex-1">
							{
								flatNumbers.map((n) => (
									<div
										data-bet-type="straight"
										data-bet-target={String(n)}
										role="button"
										tabindex="0"
										class="bet-cell flex items-center justify-center text-white font-bold text-sm rounded-sm"
										style={`background-color: ${pocketBg(n)};`}
									>
										{n}
									</div>
								))
							}
						</div>

						<!-- Column bets (2:1) -->
						<div class="flex flex-col gap-0.5">
							{
								[0, 1, 2].map((ci) => (
									<div
										data-bet-type="column"
										data-bet-target={String(ci)}
										role="button"
										tabindex="0"
										class="bet-cell flex flex-col items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-xs rounded-r-sm px-2"
										style="background-color: rgba(255,255,255,0.05);"
									>
										<span class="text-[10px] text-[var(--deco-muted)]">
											{['3rd', '2nd', '1st'][ci]}
										</span>
										<span>2:1</span>
									</div>
								))
							}
						</div>
					</div>

					<!-- Dozens -->
					<div class="grid grid-cols-3 gap-1">
						{
							[
								{ target: '0', label: '1st 12' },
								{ target: '1', label: '2nd 12' },
								{ target: '2', label: '3rd 12' },
							].map((d) => (
								<div
									data-bet-type="dozen"
									data-bet-target={d.target}
									role="button"
									tabindex="0"
									class="bet-cell flex items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-sm rounded py-2"
									style="background-color: rgba(255,255,255,0.04);"
								>
									{d.label}
								</div>
							))
						}
					</div>

					<!-- Outside bets -->
					<div class="grid grid-cols-6 gap-1">
						<div
							data-bet-type="low"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-sm rounded py-2"
							style="background-color: rgba(255,255,255,0.04);"
						>
							1-18
						</div>
						<div
							data-bet-type="even"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-sm rounded py-2"
							style="background-color: rgba(255,255,255,0.04);"
						>
							EVEN
						</div>
						<div
							data-bet-type="red"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-white font-bold text-sm rounded py-2"
							style="background-color: #b91c1c;"
						>
							RED
						</div>
						<div
							data-bet-type="black"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-white font-bold text-sm rounded py-2"
							style="background-color: #171717;"
						>
							BLACK
						</div>
						<div
							data-bet-type="odd"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-sm rounded py-2"
							style="background-color: rgba(255,255,255,0.04);"
						>
							ODD
						</div>
						<div
							data-bet-type="high"
							role="button"
							tabindex="0"
							class="bet-cell flex items-center justify-center text-[var(--deco-ivory-dim)] font-bold text-sm rounded py-2"
							style="background-color: rgba(255,255,255,0.04);"
						>
							19-36
						</div>
					</div>
				</div>
				<!-- /betting-table -->

				<!-- Chip Selector + Controls -->
				<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-4 border border-[var(--deco-line)]">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<div class="flex gap-2 flex-wrap">
							{
								CHIP_DENOMINATIONS.map((amount, i) => (
									<button
										class={`chip-select hover:scale-110 transition-transform${amount === 5 ? ' selected' : ''}`}
										data-amount={amount}
										data-testid={`chip-${amount}`}
										aria-pressed={amount === 5 ? 'true' : 'false'}
									>
										<PokerChip value={amount} color={chipColors[i]} />
									</button>
								))
							}
						</div>
						<div class="flex items-center gap-3">
							<div>
								<span class="text-[var(--deco-muted)] text-sm">Total Bet:</span>
								<span
									id="total-bet"
									data-testid="total-bet"
									class="text-[var(--deco-brass)] font-bold ml-1">$0</span
								>
							</div>
							<button
								id="clear-bets-button"
								data-testid="clear-bets-button"
								class="px-3 py-2 bg-[var(--deco-obsidian-3)] hover:bg-[var(--deco-line)] text-[var(--deco-ivory)] rounded-lg text-sm transition-colors"
							>
								Clear
							</button>
							<button
								id="spin-button"
								data-testid="spin-button"
								disabled
								class="btn-gold px-6 py-2 rounded-xl font-bold text-sm disabled:opacity-40 disabled:cursor-not-allowed"
							>
								SPIN
							</button>
							<button
								id="new-round-button"
								data-testid="new-round-button"
								hidden
								class="btn-gold px-6 py-2 rounded-xl font-bold text-sm"
							>
								NEW ROUND
							</button>
						</div>
					</div>
				</div>
			</div>
			<!-- /main game area -->

			<!-- Sidebar (1 col) -->
			<div class="space-y-4">
				<!-- Active Bets -->
				<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-4 border border-[var(--deco-line)]">
					<h3 class="text-xs font-bold text-[var(--deco-muted)] uppercase tracking-wider mb-3">
						Active Bets
					</h3>
					<div id="active-bets" data-testid="active-bets" class="space-y-1 min-h-[40px]">
						<span class="text-[var(--deco-muted)] text-xs">No bets placed</span>
					</div>
					<p class="text-[var(--deco-muted)] text-xs mt-2">Click a bet to remove it.</p>
				</div>

				<!-- Round History -->
				<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-4 border border-[var(--deco-line)]">
					<h3 class="text-xs font-bold text-[var(--deco-muted)] uppercase tracking-wider mb-3">
						Round History
					</h3>
					<div
						id="round-history"
						data-testid="round-history"
						class="flex flex-wrap gap-1.5 min-h-[32px]"
					>
						<span class="text-[var(--deco-muted)] text-xs">No rounds yet</span>
					</div>
				</div>

				<!-- Rules / Payouts -->
				<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-4 border border-[var(--deco-line)]">
					<button
						id="rules-toggle"
						type="button"
						data-testid="rules-toggle"
						aria-expanded="false"
						aria-controls="rules-panel"
						class="flex w-full items-center justify-between text-xs font-bold text-[var(--deco-muted)] uppercase tracking-wider"
					>
						<span>Payouts</span>
						<span id="rules-toggle-icon" aria-hidden="true">▸</span>
					</button>
					<div id="rules-panel" hidden class="mt-3">
						<div class="space-y-1 text-xs">
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">Straight (single)</span>
								<span class="text-[var(--deco-muted)]">35:1</span>
							</div>
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">Red / Black</span>
								<span class="text-[var(--deco-muted)]">1:1</span>
							</div>
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">Odd / Even</span>
								<span class="text-[var(--deco-muted)]">1:1</span>
							</div>
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">1-18 / 19-36</span>
								<span class="text-[var(--deco-muted)]">1:1</span>
							</div>
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">Dozens</span>
								<span class="text-[var(--deco-muted)]">2:1</span>
							</div>
							<div class="flex justify-between">
								<span class="text-[var(--deco-ivory-dim)]">Columns</span>
								<span class="text-[var(--deco-muted)]">2:1</span>
							</div>
						</div>
						<p class="text-[var(--deco-muted)] text-xs mt-3">
							Single-zero wheel · house edge 2.7%.
						</p>
					</div>
				</div>
			</div>
			<!-- /sidebar -->
		</div>
		<!-- /grid -->

		<!-- Achievement Toast -->
		<div
			id="achievement-toast"
			data-testid="achievement-toast"
			role="status"
			aria-live="polite"
			aria-atomic="true"
			class="fixed bottom-4 right-4 bg-linear-to-r from-[var(--deco-brass-bright)] to-[var(--deco-brass)] text-[var(--deco-obsidian)] px-5 py-4 rounded-xl shadow-2xl flex items-center gap-3 transition-all duration-300 opacity-0 pointer-events-none translate-y-4"
			style="z-index: 9999;"
		>
			<span id="achievement-icon" data-testid="achievement-icon" class="text-3xl">🏆</span>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider opacity-80">
					Achievement Unlocked
				</p>
				<p id="achievement-name" data-testid="achievement-name" class="font-bold text-lg">
					Achievement Name
				</p>
			</div>
		</div>
	</div>
	<!-- /roulette-root -->
</CasinoLayout>

<style>
	.roulette-table {
		background: linear-gradient(135deg, #0a3d28 0%, #073020 50%, #052518 100%);
		box-shadow:
			inset 0 0 80px rgba(0, 0, 0, 0.3),
			0 8px 32px rgba(0, 0, 0, 0.5);
	}

	.bet-cell {
		cursor: pointer;
		transition: all 0.15s ease;
		border: 1px solid rgba(255, 255, 255, 0.08);
		user-select: none;
	}
	.bet-cell:hover {
		filter: brightness(1.35);
		border-color: color-mix(in srgb, var(--deco-brass) 60%, transparent);
		transform: translateY(-1px);
	}
	.bet-cell:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--deco-brass) 90%, transparent);
		outline-offset: 1px;
	}

	.wheel-container {
		width: 220px;
		height: 220px;
	}
	.roulette-wheel-inner {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		/* Keep in sync with SPIN_ANIMATION_MS in src/lib/roulette/constants.ts */
		transition: transform 4s cubic-bezier(0.17, 0.67, 0.12, 0.99);
		box-shadow:
			0 0 0 4px var(--deco-brass-dim),
			0 0 0 6px var(--deco-obsidian),
			0 8px 32px rgba(0, 0, 0, 0.6);
	}
	.wheel-pointer {
		position: absolute;
		top: -6px;
		left: 50%;
		transform: translateX(-50%);
		color: var(--deco-brass-bright);
		font-size: 1.4rem;
		line-height: 1;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
		z-index: 10;
	}

	.chip-select {
		transition: transform 0.15s ease;
	}
	.chip-select.selected {
		transform: scale(1.2);
		filter: drop-shadow(0 0 8px color-mix(in srgb, var(--deco-brass) 50%, transparent));
	}

	.round-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 50%;
		font-size: 10px;
		font-weight: bold;
	}
	.round-red {
		background: #b91c1c;
		color: white;
	}
	.round-black {
		background: #171717;
		color: white;
	}
	.round-green {
		background: #0a7a3a;
		color: white;
	}
</style>

<script>
	import { initRouletteClient } from '../../lib/roulette/rouletteClient';

	initRouletteClient();
</script>
