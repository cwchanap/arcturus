---
interface Props {
	kind: 'cards' | 'dice' | 'wheel' | 'spark';
	size?: number;
	class?: string;
}

const { kind, size = 72, class: className = '' } = Astro.props;
---

<svg
	width={size}
	height={size}
	viewBox="0 0 64 64"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={className}
	aria-hidden="true"
>
	{
		kind === 'cards' && (
			<>
				<rect x="13" y="20" width="24" height="32" rx="3" transform="rotate(-11 25 36)" />
				<rect x="27" y="14" width="24" height="32" rx="3" transform="rotate(9 39 30)" />
				<path
					d="M39 24 L43 30 L39 36 L35 30 Z"
					fill="currentColor"
					stroke="none"
					transform="rotate(9 39 30)"
				/>
			</>
		)
	}
	{
		kind === 'dice' && (
			<>
				<rect x="11" y="22" width="23" height="23" rx="4" transform="rotate(-8 22 33)" />
				<rect x="31" y="16" width="23" height="23" rx="4" transform="rotate(7 42 27)" />
				<g fill="currentColor" stroke="none">
					<circle cx="18" cy="29" r="1.6" />
					<circle cx="26" cy="37" r="1.6" />
					<circle cx="38" cy="22" r="1.6" />
					<circle cx="46" cy="22" r="1.6" />
					<circle cx="38" cy="32" r="1.6" />
					<circle cx="46" cy="32" r="1.6" />
				</g>
			</>
		)
	}
	{
		kind === 'wheel' && (
			<>
				<circle cx="32" cy="32" r="22" />
				<circle cx="32" cy="32" r="13" />
				<circle cx="32" cy="32" r="2.6" fill="currentColor" stroke="none" />
				<line x1="32" y1="10" x2="32" y2="19" />
				<line x1="32" y1="45" x2="32" y2="54" />
				<line x1="10" y1="32" x2="19" y2="32" />
				<line x1="45" y1="32" x2="54" y2="32" />
				<line x1="16.5" y1="16.5" x2="23" y2="23" />
				<line x1="41" y1="41" x2="47.5" y2="47.5" />
				<line x1="47.5" y1="16.5" x2="41" y2="23" />
				<line x1="23" y1="41" x2="16.5" y2="47.5" />
			</>
		)
	}
	{
		kind === 'spark' && (
			<>
				<path d="M32 8 L37 26 L55 32 L37 38 L32 56 L27 38 L9 32 L27 26 Z" />
				<circle cx="32" cy="32" r="3.5" fill="currentColor" stroke="none" />
			</>
		)
	}
</svg>
