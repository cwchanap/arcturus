---
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'outline' | 'ghost';

// Anchor-only primitive. All current call sites use `href`. If a real `<button>`
// is needed later, reintroduce a discriminated union — don't add a dead branch.
type Props = Omit<HTMLAttributes<'a'>, 'class'> & {
	variant?: Variant;
	href: string;
	class?: string;
};

const { variant = 'primary', href, class: className = '', ...rest } = Astro.props;

const variantClass =
	variant === 'outline'
		? 'deco-btn-outline'
		: variant === 'ghost'
			? 'deco-btn-ghost'
			: 'deco-btn-primary';

const cls = `deco-btn ${variantClass} ${className}`.trim();
---

<a href={href} class={cls} {...rest as Omit<HTMLAttributes<'a'>, 'class'>}>
	<slot />
</a>
