---
import CasinoLayout from '../../layouts/casino.astro';
import { createDb } from '../../lib/db';
import { getLeaderboardData } from '../../lib/leaderboard/leaderboard';
import type { LeaderboardData } from '../../lib/leaderboard/types';
import {
	getGameLeaderboardData,
	GAME_TYPES,
	RANKING_METRICS,
	GAME_TYPE_LABELS,
	GAME_TYPE_ICONS,
	RANKING_METRIC_LABELS,
	isValidGameType,
	isValidRankingMetric,
	type GameLeaderboardData,
} from '../../lib/game-stats/game-stats';
import DecoIcon from '../../components/DecoIcon.astro';

const session = Astro.locals.session;

// Handle build-time and runtime edge cases (consistent with missions/daily.astro)
if (!session || !Astro.locals.runtime?.env?.DB) {
	if (!session) {
		return Astro.redirect('/signin');
	}
	// During build, return a loading state or error page
	return new Response('Service temporarily unavailable', { status: 503 });
}

const user = session.user;
const dbBinding = Astro.locals.runtime.env.DB;

// Parse query parameters for tab and metric selection
const selectedTabRaw = Astro.url.searchParams.get('game') || 'all';
const selectedMetric = Astro.url.searchParams.get('metric') || 'wins';

// Validate and normalize parameters
const isGameTab = selectedTabRaw !== 'all' && isValidGameType(selectedTabRaw);
const selectedTab = isGameTab ? selectedTabRaw : 'all';
const validMetric = isValidRankingMetric(selectedMetric) ? selectedMetric : 'wins';

// Fetch leaderboard data server-side
let overallLeaderboardData: LeaderboardData | null = null;
let gameLeaderboardData: GameLeaderboardData | null = null;
let errorMessage: string | null = null;

try {
	const db = createDb(dbBinding);

	if (isGameTab) {
		// Fetch game-specific leaderboard
		gameLeaderboardData = await getGameLeaderboardData(db, {
			gameType: selectedTab as (typeof GAME_TYPES)[number],
			rankingMetric: validMetric as (typeof RANKING_METRICS)[number],
			limit: 50,
			currentUserId: user.id,
		});
	} else {
		// Fetch overall leaderboard (chip balance)
		overallLeaderboardData = await getLeaderboardData(db, {
			limit: 50,
			currentUserId: user.id,
		});
	}
} catch (error) {
	console.error('Leaderboard fetch error:', error);
	errorMessage = 'Failed to load leaderboard. Please try again.';
}

// Format numbers for display (chips, counts, etc.)
function formatNumber(amount: number): string {
	return new Intl.NumberFormat('en-US').format(amount);
}

// Format metric value based on type
function formatMetricValue(value: number, metric: string): string {
	if (metric === 'win_rate') {
		return `${value.toFixed(1)}%`;
	}
	return formatNumber(value);
}

// Tab configuration
const tabs = [
	{ id: 'all', label: 'All Games', icon: '🏆' },
	...GAME_TYPES.map((type) => ({
		id: type,
		label: GAME_TYPE_LABELS[type],
		icon: GAME_TYPE_ICONS[type],
	})),
];

// Get current rank info for display
const currentUserRank = isGameTab
	? gameLeaderboardData?.currentUserRank
	: overallLeaderboardData?.currentUserRank;
const totalPlayers = isGameTab
	? gameLeaderboardData?.totalPlayers
	: overallLeaderboardData?.totalPlayers;
const currentUserInTop = isGameTab
	? gameLeaderboardData?.currentUserInTop
	: overallLeaderboardData?.currentUserInTop;
---

<CasinoLayout title="Leaderboard - Arcturus Casino">
	<section class="deco-atmosphere relative overflow-hidden">
		<div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<header class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-8">
				<div>
					<a href="/" class="deco-link mb-4 inline-flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 19l-7-7 7-7"></path>
						</svg>
						Back to Lobby
					</a>
					<h1 class="deco-section-title flex items-center gap-3 text-4xl">
						<DecoIcon name="trophy" size={34} class="text-[var(--deco-brass)]" />
						<span>Leaderboard</span>
					</h1>
					<p class="deco-text-dim mt-2">
						{
							isGameTab
								? `${GAME_TYPE_LABELS[selectedTab]} rankings`
								: 'Top players ranked by chip balance'
						}
					</p>
				</div>

				{
					currentUserRank && (
						<div class="deco-panel deco-frame px-6 py-4 text-center md:text-right">
							<p class="deco-eyebrow-sm">Your Rank</p>
							<p class="deco-stat-value mt-1 text-3xl">#{currentUserRank}</p>
							<p class="deco-muted-text text-xs mt-1">
								of {formatNumber(totalPlayers ?? 0)} players
							</p>
						</div>
					)
				}
			</header>

			<!-- Tabs -->
			<div class="flex gap-2 mb-6 overflow-x-auto pb-2" data-testid="leaderboard-tabs">
				{
					tabs.map((tab) => (
						<a
							href={`/games/leaderboard?game=${tab.id}${tab.id !== 'all' ? `&metric=${validMetric}` : ''}`}
							class:list={[
								'deco-tab px-4 py-2 font-medium whitespace-nowrap flex items-center gap-2',
								selectedTab === tab.id && 'deco-tab-active',
							]}
							data-testid={`tab-${tab.id}`}
						>
							<span>{tab.icon}</span>
							<span>{tab.label}</span>
						</a>
					))
				}
			</div>

			<!-- Metric selector (only for game tabs) -->
			{
				isGameTab && (
					<div class="flex items-center gap-3 mb-6">
						<span class="deco-text-dim text-sm">Rank by:</span>
						<div class="flex gap-2" data-testid="metric-selector">
							{RANKING_METRICS.map((metric) => (
								<a
									href={`/games/leaderboard?game=${selectedTab}&metric=${metric}`}
									class:list={[
										'deco-tab px-3 py-1.5 text-xs font-medium',
										validMetric === metric && 'deco-tab-active',
									]}
									data-testid={`metric-${metric}`}
								>
									{RANKING_METRIC_LABELS[metric]}
								</a>
							))}
						</div>
					</div>
				)
			}

			{
				errorMessage && (
					<div
						class="deco-panel p-8 text-center"
						style="border-color: rgba(154,45,51,0.5); background: rgba(110,31,35,0.15)"
					>
						<p class="text-lg" style="color: var(--deco-rose)">
							{errorMessage}
						</p>
						<button onclick="window.location.reload()" class="deco-btn deco-btn-outline mt-4">
							Try Again
						</button>
					</div>
				)
			}

			<!-- Overall Leaderboard Table -->
			{
				!errorMessage &&
					!isGameTab &&
					overallLeaderboardData &&
					overallLeaderboardData.entries.length > 0 && (
						<div class="deco-panel overflow-hidden">
							<div class="overflow-x-auto">
								<table class="w-full" data-testid="leaderboard-table">
									<thead class="deco-table-head">
										<tr>
											<th class="deco-th px-6 py-4 text-left">Rank</th>
											<th class="deco-th px-6 py-4 text-left">Player</th>
											<th class="deco-th px-6 py-4 text-left">Badges</th>
											<th class="deco-th px-6 py-4 text-right">Chip Balance</th>
										</tr>
									</thead>
									<tbody style="border-top: 1px solid rgba(200,165,92,0.12)">
										{overallLeaderboardData.entries.map((entry) => {
											const rankEmoji =
												entry.rank === 1
													? '🥇'
													: entry.rank === 2
														? '🥈'
														: entry.rank === 3
															? '🥉'
															: '';

											return (
												<tr
													class:list={[entry.isCurrentUser ? 'deco-row-active' : 'deco-row']}
													style="border-bottom: 1px solid rgba(200,165,92,0.1)"
													data-testid={entry.isCurrentUser ? 'current-user-row' : undefined}
												>
													<td class="px-6 py-4 whitespace-nowrap">
														<span class="deco-text-dim font-semibold flex items-center gap-2">
															{rankEmoji && <span class="text-xl">{rankEmoji}</span>}
															<span>#{entry.rank}</span>
														</span>
													</td>
													<td class="px-6 py-4 whitespace-nowrap">
														<div class="flex items-center gap-3">
															<span
																class:list={[
																	'font-medium',
																	entry.isCurrentUser ? 'deco-accent' : 'deco-text',
																]}
															>
																{entry.playerName || 'Anonymous'}
															</span>
															{entry.isCurrentUser && <span class="deco-tag">You</span>}
														</div>
													</td>
													<td class="px-6 py-4 whitespace-nowrap" data-testid="badges-cell">
														<span class="text-lg">
															{entry.badges.length > 0 ? entry.badges.join(' ') : '—'}
														</span>
													</td>
													<td class="px-6 py-4 whitespace-nowrap text-right">
														<span
															class:list={[
																'font-bold tabular-nums',
																entry.isCurrentUser ? 'deco-accent' : 'deco-text',
															]}
														>
															{formatNumber(entry.chipBalance)}
														</span>
														<span class="deco-muted-text text-sm ml-1">chips</span>
													</td>
												</tr>
											);
										})}
									</tbody>
								</table>
							</div>

							{!currentUserInTop && currentUserRank && (
								<div
									class="p-4 text-center"
									style="border-top: 1px solid rgba(200,165,92,0.2); background: rgba(12,51,38,0.3)"
								>
									<p class="deco-text-dim text-sm">
										You're ranked
										<span class="deco-accent font-bold">#{currentUserRank}</span>. Keep playing to
										reach the top 50!
									</p>
								</div>
							)}
						</div>
					)
			}

			<!-- Game-Specific Leaderboard Table -->
			{
				!errorMessage &&
					isGameTab &&
					gameLeaderboardData &&
					gameLeaderboardData.entries.length > 0 && (
						<div class="deco-panel overflow-hidden">
							<div class="overflow-x-auto">
								<table class="w-full" data-testid="game-leaderboard-table">
									<thead class="deco-table-head">
										<tr>
											<th class="deco-th px-6 py-4 text-left">Rank</th>
											<th class="deco-th px-6 py-4 text-left">Player</th>
											<th class="deco-th px-6 py-4 text-left">Badges</th>
											<th class="deco-th px-6 py-4 text-right">
												{RANKING_METRIC_LABELS[validMetric]}
											</th>
											<th class="deco-th px-6 py-4 text-right">Stats</th>
										</tr>
									</thead>
									<tbody style="border-top: 1px solid rgba(200,165,92,0.12)">
										{gameLeaderboardData.entries.map((entry) => {
											const rankEmoji =
												entry.rank === 1
													? '🥇'
													: entry.rank === 2
														? '🥈'
														: entry.rank === 3
															? '🥉'
															: '';

											return (
												<tr
													class:list={[entry.isCurrentUser ? 'deco-row-active' : 'deco-row']}
													style="border-bottom: 1px solid rgba(200,165,92,0.1)"
													data-testid={entry.isCurrentUser ? 'current-user-row' : undefined}
												>
													<td class="px-6 py-4 whitespace-nowrap">
														<span class="deco-text-dim font-semibold flex items-center gap-2">
															{rankEmoji && <span class="text-xl">{rankEmoji}</span>}
															<span>#{entry.rank}</span>
														</span>
													</td>
													<td class="px-6 py-4 whitespace-nowrap">
														<div class="flex items-center gap-3">
															<span
																class:list={[
																	'font-medium',
																	entry.isCurrentUser ? 'deco-accent' : 'deco-text',
																]}
															>
																{entry.playerName || 'Anonymous'}
															</span>
															{entry.isCurrentUser && <span class="deco-tag">You</span>}
														</div>
													</td>
													<td class="px-6 py-4 whitespace-nowrap" data-testid="badges-cell">
														<span class="text-lg">
															{entry.badges.length > 0 ? entry.badges.join(' ') : '—'}
														</span>
													</td>
													<td class="px-6 py-4 whitespace-nowrap text-right">
														<span
															class:list={[
																'font-bold tabular-nums',
																entry.isCurrentUser ? 'deco-accent' : 'deco-text',
															]}
														>
															{formatMetricValue(entry.metricValue, validMetric)}
														</span>
													</td>
													<td class="px-6 py-4 whitespace-nowrap text-right">
														<div class="deco-muted-text text-xs">
															<div>{entry.totalWins} wins</div>
															<div>{entry.handsPlayed} hands</div>
														</div>
													</td>
												</tr>
											);
										})}
									</tbody>
								</table>
							</div>

							{!currentUserInTop && currentUserRank && (
								<div
									class="p-4 text-center"
									style="border-top: 1px solid rgba(200,165,92,0.2); background: rgba(12,51,38,0.3)"
								>
									<p class="deco-text-dim text-sm">
										You're ranked
										<span class="deco-accent font-bold">#{currentUserRank}</span> in{' '}
										{GAME_TYPE_LABELS[selectedTab]}. Keep playing to reach the top 50!
									</p>
								</div>
							)}
						</div>
					)
			}

			<!-- Empty State -->
			{
				!errorMessage &&
					((isGameTab &&
						(gameLeaderboardData == null || gameLeaderboardData.entries.length === 0)) ||
						(!isGameTab &&
							(overallLeaderboardData == null || overallLeaderboardData.entries.length === 0))) && (
						<div class="deco-panel deco-frame p-12 text-center">
							<div class="text-6xl mb-4">{isGameTab ? GAME_TYPE_ICONS[selectedTab] : '🏆'}</div>
							<p class="deco-text-dim text-lg">No players found</p>
							<p class="deco-muted-text text-sm mt-2">
								{isGameTab
									? `Be the first to play ${GAME_TYPE_LABELS[selectedTab]} and claim the top spot!`
									: 'Be the first to claim the top spot!'}
							</p>
						</div>
					)
			}

			<div class="deco-panel mt-8 p-6">
				<h3 class="deco-section-title mb-3 flex items-center gap-2 text-lg">
					<DecoIcon name="star" size={18} class="text-[var(--deco-brass)]" />
					<span>How Rankings Work</span>
				</h3>
				<ul class="deco-text-dim space-y-2 text-sm">
					{
						isGameTab ? (
							<>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>
										Game leaderboards track your performance in {GAME_TYPE_LABELS[selectedTab]}
									</span>
								</li>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>Rank by Total Wins, Win Rate, Biggest Win, or Net Profit</span>
								</li>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>
										Win Rate requires at least 10 decided games (wins or losses) to appear on the
										leaderboard
									</span>
								</li>
							</>
						) : (
							<>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>Players are ranked by total chip balance (highest first)</span>
								</li>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>Only the top 50 players are displayed on this leaderboard</span>
								</li>
								<li class="flex items-start gap-2">
									<span class="deco-accent-dim">&bull;</span>
									<span>Earn chips by playing games and completing daily missions</span>
								</li>
							</>
						)
					}
					<li class="flex items-start gap-2">
						<span class="deco-accent-dim">&bull;</span>
						<span>Rankings update automatically as you play</span>
					</li>
				</ul>
			</div>
		</div>
	</section>
</CasinoLayout>
