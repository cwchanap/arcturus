# Better Auth Secret (generate with: openssl rand -base64 32)
# This is REQUIRED for authentication to work
BETTER_AUTH_SECRET=development-secret-change-in-production

# Cloudflare D1 Database (for local development)
D1_DATABASE=arcturus

# Cloudflare KV Namespace (for sessions)
SESSION_NAMESPACE=arcturus-session-placeholder

# Multiplayer internal auth (shared between DO and Worker)
MP_AUTH_SECRET=dev-mp-auth-secret

# Worker origin for DO → Worker internal calls (local dev only)
WORKER_ORIGIN=http://localhost:2000