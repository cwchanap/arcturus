---
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'a'>, 'class'> {
	variant?: 'primary' | 'outline' | 'ghost';
	href?: string;
	type?: 'button' | 'submit';
	class?: string;
}

const { variant = 'primary', href, type = 'button', class: className = '', ...rest } = Astro.props;

const variantClass =
	variant === 'outline'
		? 'deco-btn-outline'
		: variant === 'ghost'
			? 'deco-btn-ghost'
			: 'deco-btn-primary';

const cls = `deco-btn ${variantClass} ${className}`.trim();
---

{
	href ? (
		<a href={href} class={cls} {...rest}>
			<slot />
		</a>
	) : (
		<button type={type} class={cls} {...rest}>
			<slot />
		</button>
	)
}
