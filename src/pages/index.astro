---
import CasinoLayout from '../layouts/casino.astro';
import GameCard from '../components/GameCard.astro';
import Button from '../components/Button.astro';
import DecoDivider from '../components/DecoDivider.astro';
import DecoIcon from '../components/DecoIcon.astro';

// Check if user is logged in
const user = Astro.locals.user;

const games = [
	{
		name: "Texas Hold'em Poker",
		emblem: 'cards' as const,
		players: 1247,
		minBet: 10,
		href: '/games/poker',
		featured: true,
	},
	{
		name: 'Poker (Multiplayer)',
		emblem: 'cards' as const,
		players: 0,
		minBet: 10,
		href: '/games/poker-mp',
		featured: true,
	},
	{
		name: 'Blackjack',
		emblem: 'cards' as const,
		players: 892,
		minBet: 5,
		href: '/games/blackjack',
		featured: true,
	},
	{
		name: 'Roulette',
		emblem: 'wheel' as const,
		players: 654,
		minBet: 1,
		href: '/games/roulette',
	},
	{
		name: 'Baccarat',
		emblem: 'cards' as const,
		players: 432,
		minBet: 10,
		href: '/games/baccarat',
		featured: true,
	},
	{
		name: 'Craps',
		emblem: 'dice' as const,
		players: 321,
		minBet: 5,
		href: '/games/craps',
		featured: true,
	},
	{
		name: 'Slots',
		emblem: 'spark' as const,
		players: 2134,
		minBet: 1,
		href: '/games/slots',
	},
];

const featuredGames = games.filter((game) => game.featured);

const features = [
	{
		icon: 'chip' as const,
		title: 'No Real Money',
		body: 'Play with virtual chips only. All the thrill of the casino floor, none of the risk.',
	},
	{
		icon: 'star' as const,
		title: 'Unlimited Play',
		body: 'Out of chips? Claim a daily bonus and return to the table. The night never ends.',
	},
	{
		icon: 'trophy' as const,
		title: 'Sharpen Your Game',
		body: 'Refine your strategy and read the table in a risk-free room built for mastery.',
	},
];
---

<CasinoLayout
	title="Arcturus Casino - Premium Online Gaming"
	bodyClass="bg-[var(--deco-obsidian)] text-[var(--deco-ivory)]"
>
	<!-- Hero -->
	<section class="deco-atmosphere deco-grain relative overflow-hidden">
		<!-- Sunburst motif behind the headline -->
		<div
			class="pointer-events-none absolute inset-0 flex items-start justify-center opacity-[0.06]"
		>
			<svg
				width="900"
				height="900"
				viewBox="0 0 200 200"
				class="mt-[-120px]"
				fill="none"
				stroke="var(--deco-brass)"
				stroke-width="0.4"
				aria-hidden="true"
			>
				{
					Array.from({ length: 48 }).map((_, i) => {
						const a = (i / 48) * Math.PI * 2;
						return (
							<line x1="100" y1="100" x2={100 + Math.cos(a) * 130} y2={100 + Math.sin(a) * 130} />
						);
					})
				}
			</svg>
		</div>

		<div class="relative mx-auto max-w-5xl px-4 py-24 text-center sm:px-6 lg:px-8 lg:py-32">
			<p class="deco-section-eyebrow mb-6">Est. MMXXV &middot; Premium Play</p>
			<h1 class="deco-display mx-auto max-w-4xl text-5xl md:text-7xl">
				Welcome to <em>Arcturus</em>
			</h1>
			<div class="mx-auto my-8 max-w-xs">
				<DecoDivider />
			</div>
			<p class="deco-body-text mx-auto mb-10 max-w-2xl text-lg md:text-xl">
				A virtual casino built for the thrill of the game. Play poker, blackjack, baccarat and more
				&mdash; 100% free, no real money required.
			</p>

			{
				!user ? (
					<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
						<Button href="/signin" variant="primary">
							Join Free &mdash; Get 10,000 Chips
						</Button>
						<Button href="/signin" variant="outline">
							Sign In
						</Button>
					</div>
				) : (
					<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
						<Button href="#games" variant="primary">
							Play Now
						</Button>
						<Button href="/missions/daily" variant="outline">
							Daily Mission
						</Button>
						<Button href="/profile" variant="outline">
							Dashboard
						</Button>
					</div>
				)
			}

			<div class="mx-auto mt-16 grid max-w-3xl grid-cols-1 gap-px overflow-hidden sm:grid-cols-3">
				<div class="deco-panel deco-frame px-6 py-8">
					<div class="deco-stat-value text-4xl">100%</div>
					<div class="deco-stat-label mt-2">Free to Play</div>
				</div>
				<div class="deco-panel deco-frame px-6 py-8">
					<div class="deco-stat-value text-4xl tabular-nums">5,680+</div>
					<div class="deco-stat-label mt-2">Players Online</div>
				</div>
				<div class="deco-panel deco-frame px-6 py-8">
					<div class="deco-stat-value text-4xl">10K</div>
					<div class="deco-stat-label mt-2">Starting Chips</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Games -->
	<section id="games" class="mx-auto max-w-7xl space-y-20 px-4 py-24 sm:px-6 lg:px-8">
		<div class="text-center">
			<p class="deco-section-eyebrow mb-4">The Floor</p>
			<h2 class="deco-section-title text-4xl">Featured Tables</h2>
			<div class="mx-auto mt-6 max-w-sm">
				<DecoDivider />
			</div>
		</div>

		<div class="grid grid-cols-1 gap-8 md:grid-cols-3">
			{featuredGames.map((game) => <GameCard {...game} />)}
		</div>

		<div class="space-y-10">
			<div>
				<p class="deco-section-eyebrow mb-3">Full Lineup</p>
				<h3 class="deco-section-title text-3xl">All Games</h3>
				<p class="deco-body-text mt-3 max-w-2xl">
					Sharpen your skills across the full table lineup. Everything is free to play &mdash; earn
					chips, test new strategies, and find your next favorite game.
				</p>
			</div>
			<div class="grid grid-cols-1 gap-8 md:grid-cols-3">
				{games.map((game) => <GameCard {...game} />)}
			</div>
		</div>

		<!-- Welcome bonus -->
		<div
			class="deco-panel deco-frame deco-grain relative overflow-hidden px-8 py-14 text-center md:px-12"
		>
			<p class="deco-section-eyebrow mb-4">House Welcome</p>
			<h3 class="deco-section-title text-3xl md:text-4xl">A Toast to New Players</h3>
			<p class="deco-body-text mx-auto mt-4 max-w-xl">
				Claim a 100% chip match on your first refill, plus a standing invitation to the private VIP
				tables.
			</p>
			<div class="mt-8 flex justify-center">
				<Button href="/missions/daily" variant="primary">Claim Bonus</Button>
			</div>
		</div>
	</section>

	<!-- Why Arcturus -->
	<section class="deco-atmosphere border-y border-[var(--deco-brass)]/15">
		<div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
			<div class="mb-16 text-center">
				<p class="deco-section-eyebrow mb-4">The Difference</p>
				<h2 class="deco-section-title text-4xl">Why Arcturus</h2>
			</div>
			<div class="grid grid-cols-1 gap-8 md:grid-cols-3">
				{
					features.map((feature) => (
						<div class="deco-card deco-frame p-8">
							<div
								class="mb-6 flex h-14 w-14 items-center justify-center rounded-sm border"
								style="border-color: var(--deco-brass); color: var(--deco-brass)"
							>
								<DecoIcon name={feature.icon} size={26} />
							</div>
							<h3 class="deco-section-title mb-3 text-2xl">{feature.title}</h3>
							<p class="deco-body-text">{feature.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Closing CTA -->
	{
		!user && (
			<section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
				<div class="deco-panel deco-frame deco-grain relative overflow-hidden px-8 py-16 text-center md:px-16">
					<p class="deco-section-eyebrow mb-5">Take Your Seat</p>
					<h2 class="deco-display text-4xl md:text-5xl">
						Ready when <em>you</em> are
					</h2>
					<p class="deco-body-text mx-auto mt-5 max-w-xl text-lg">
						Join Arcturus today and start with 10,000 virtual chips. No credit card, no catch
						&mdash; just the game.
					</p>
					<div class="mt-9 flex justify-center">
						<Button href="/signin" variant="primary">
							Start Playing Free
						</Button>
					</div>
				</div>
			</section>
		)
	}
</CasinoLayout>
