---
import CasinoLayout from '../../../layouts/casino.astro';
import { isValidRoomCode } from '../../../lib/mp-poker/roomCode';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/signin');
const code = Astro.params.code;
if (!code || !isValidRoomCode(code)) {
	return new Response('Not found', { status: 404 });
}
---

<CasinoLayout title={`Poker ${code} — Arcturus`}>
	<div class="max-w-4xl mx-auto p-4 space-y-4" data-room-code={code}>
		<header class="flex justify-between items-center">
			<h1 class="deco-section-title text-2xl">Room {code}</h1>
			<span data-testid="connection-status" class="text-[var(--deco-jade)]">Connecting…</span>
		</header>

		<div
			data-testid="table"
			class="bg-[var(--deco-emerald-deep)] rounded-lg p-6 border border-[var(--deco-brass-dim)]"
		>
			<div data-testid="board" class="flex gap-2 justify-center min-h-24"></div>
			<div data-testid="pot" class="text-center text-[var(--deco-brass-bright)] mt-3"></div>
		</div>

		<div data-testid="seats" class="grid grid-cols-3 gap-3"></div>

		<div data-testid="hole-cards" class="flex gap-2 justify-center min-h-24"></div>

		<div class="flex gap-2 justify-center" data-testid="actions">
			<button
				data-action="fold"
				class="bg-[var(--deco-oxblood-bright)] px-4 py-2 rounded text-white">Fold</button
			>
			<button data-action="check" class="bg-[var(--deco-obsidian-3)] px-4 py-2 rounded text-white"
				>Check</button
			>
			<button data-action="call" class="bg-[var(--deco-sapphire)] px-4 py-2 rounded text-white"
				>Call</button
			>
			<input
				type="number"
				data-testid="raise-amount"
				class="bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] p-2 rounded w-32 border border-[var(--deco-line)]"
				placeholder="Amount"
			/>
			<button data-action="raise" class="bg-[var(--deco-jade)] px-4 py-2 rounded text-white"
				>Raise</button
			>
		</div>

		<div class="flex gap-3 justify-center flex-wrap">
			<button
				data-testid="take-seat-0"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 0
			</button>
			<button
				data-testid="take-seat-1"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 1
			</button>
			<button
				data-testid="take-seat-2"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 2
			</button>
			<button
				data-testid="take-seat-3"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 3
			</button>
			<button
				data-testid="take-seat-4"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 4
			</button>
			<button
				data-testid="take-seat-5"
				class="bg-[var(--deco-obsidian-3)] px-3 py-1 rounded text-white"
			>
				Sit at 5
			</button>
			<button
				data-testid="start-hand"
				class="bg-[var(--deco-brass)] px-3 py-1 rounded text-[var(--deco-obsidian)] font-semibold"
			>
				Start hand
			</button>
			<button
				data-testid="leave-seat"
				class="bg-[var(--deco-oxblood)] px-3 py-1 rounded text-white"
			>
				Leave seat
			</button>
		</div>

		<div
			data-testid="log"
			class="text-[var(--deco-ivory-dim)] text-sm space-y-1 max-h-40 overflow-auto"
		>
		</div>
	</div>
</CasinoLayout>

<script>
	import { MultiplayerPokerClient } from '../../../lib/mp-poker/client';
	import { getSuitGlyph, isRedSuit } from '../../../lib/card-format';

	const root = document.querySelector('[data-room-code]') as HTMLElement;
	const code = root.dataset.roomCode!;
	const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
	const client = new MultiplayerPokerClient(`${proto}//${location.host}/api/mp/rooms/${code}/ws`);

	const statusEl = document.querySelector('[data-testid="connection-status"]') as HTMLElement;
	const seatsEl = document.querySelector('[data-testid="seats"]') as HTMLElement;
	const boardEl = document.querySelector('[data-testid="board"]') as HTMLElement;
	const potEl = document.querySelector('[data-testid="pot"]') as HTMLElement;
	const holeEl = document.querySelector('[data-testid="hole-cards"]') as HTMLElement;
	const logEl = document.querySelector('[data-testid="log"]') as HTMLElement;
	const raiseAmt = document.querySelector('[data-testid="raise-amount"]') as HTMLInputElement;

	function createCardEl(c: { value: string; suit: string }): HTMLSpanElement {
		const glyph = getSuitGlyph(c.suit);
		const color = isRedSuit(c.suit)
			? 'text-[var(--deco-oxblood-bright)]'
			: 'text-[var(--deco-ivory)]';
		const span = document.createElement('span');
		span.className = `inline-block bg-[var(--deco-obsidian-2)] px-2 py-1 rounded ${color}`;
		span.textContent = `${c.value}${glyph}`;
		return span;
	}

	function clearAndAppend(parent: HTMLElement, children: HTMLElement[]): void {
		parent.textContent = '';
		for (const child of children) parent.appendChild(child);
	}

	client.on((msg) => {
		if (msg.type === 'room_state') {
			clearAndAppend(boardEl, msg.board.map(createCardEl));
			potEl.textContent = `Pot: ${msg.pot}`;
			// Clear stale hole cards when room is not in an active hand
			if (msg.phase !== 'in-hand') {
				holeEl.textContent = '';
			}
			seatsEl.textContent = '';
			for (const s of msg.seats) {
				const div = document.createElement('div');
				div.className =
					'bg-[var(--deco-obsidian-2)] p-3 rounded text-[var(--deco-ivory)] border border-[var(--deco-line)]';
				div.setAttribute('data-testid', `seat-${s.seatIndex}`);
				div.textContent = `Seat ${s.seatIndex}: ${s.displayName ?? '(empty)'} — ${s.committed} in pot`;
				seatsEl.appendChild(div);
			}
		} else if (msg.type === 'hand_started') {
			clearAndAppend(holeEl, msg.holeCards.map(createCardEl));
		} else if (msg.type === 'hand_ended') {
			const w = msg.winners.map((win) => `seat ${win.seatIndex} +${win.amount}`).join(', ');
			const entry = document.createElement('div');
			entry.setAttribute('data-testid', 'log-entry');
			entry.textContent = `Hand ended: ${w}`;
			logEl.prepend(entry);
			// Clear stale hole cards once the hand is over
			holeEl.textContent = '';
		} else if (msg.type === 'error') {
			const errDiv = document.createElement('div');
			errDiv.className = 'text-[var(--deco-oxblood-bright)]';
			errDiv.textContent = `Error: ${msg.message}`;
			logEl.prepend(errDiv);
		}
	});

	// Connection status helper: always reset both tone classes before applying
	// the active one so the element never retains a stale tone from a prior state.
	const STATUS_TONE_JADE = 'text-[var(--deco-jade)]';
	const STATUS_TONE_OXBLOOD = 'text-[var(--deco-oxblood-bright)]';
	function setConnectionState(text: string, tone: string) {
		statusEl.textContent = text;
		statusEl.classList.remove(STATUS_TONE_JADE, STATUS_TONE_OXBLOOD);
		statusEl.classList.add(tone);
	}

	client.onDisconnect(() => {
		setConnectionState('Disconnected', STATUS_TONE_OXBLOOD);
	});

	client
		.connect()
		.then(() => {
			setConnectionState('Connected', STATUS_TONE_JADE);
		})
		.catch(() => {
			setConnectionState('Disconnected', STATUS_TONE_OXBLOOD);
		});

	// Expose client for E2E tests to send leave_seat and other messages.
	// In production builds import.meta.env.DEV is false, so we also check a
	// build-time PUBLIC_E2E flag set by the MP Playwright config's webServer command.
	// Astro only exposes PUBLIC_* prefixed env vars to client-side code.
	if (import.meta.env.DEV || import.meta.env.PUBLIC_E2E) {
		(window as unknown as Record<string, unknown>).__mpClient = client;
	}

	document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const action = btn.dataset.action!;
			if (action === 'raise') {
				const amount = Number(raiseAmt.value);
				if (!Number.isFinite(amount) || amount <= 0 || !Number.isInteger(amount)) return;
				client.send({ type: 'action', action: 'raise', amount });
			} else {
				client.send({ type: 'action', action: action as 'fold' | 'check' | 'call' });
			}
		});
	});

	document.querySelectorAll<HTMLButtonElement>('[data-testid^="take-seat-"]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const idx = parseInt(btn.dataset.testid!.split('-').pop() ?? '', 10);
			if (!Number.isInteger(idx) || idx < 0) return;
			client.send({ type: 'take_seat', seatIndex: idx });
		});
	});

	document.querySelector('[data-testid="start-hand"]')!.addEventListener('click', () => {
		client.send({ type: 'start_hand' });
	});

	document.querySelector('[data-testid="leave-seat"]')!.addEventListener('click', () => {
		client.send({ type: 'leave_seat' });
	});
</script>
