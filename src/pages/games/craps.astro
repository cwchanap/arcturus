---
import CasinoLayout from '../../layouts/casino.astro';
import PokerChip from '../../components/PokerChip.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/signin');

const initialBalance = user.chipBalance ?? 1000;
---

<CasinoLayout title="Craps - Arcturus Casino">
	<div
		id="craps-root"
		data-user-id={user.id}
		data-initial-balance={initialBalance}
		class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
	>
		<!-- Header -->
		<div class="flex items-center justify-between mb-6">
			<div>
				<a
					href="/games"
					class="text-slate-400 hover:text-yellow-400 transition-colors mb-2 inline-block"
				>
					← Back to Games
				</a>
				<h1
					class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-amber-500"
				>
					Craps
				</h1>
			</div>
			<div class="bg-slate-800 px-6 py-3 rounded-lg border border-yellow-500/30">
				<div class="text-xs text-slate-400 mb-1">Your Balance</div>
				<div class="text-2xl font-bold text-yellow-400" id="chip-balance">
					${initialBalance.toLocaleString()}
				</div>
			</div>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
			<!-- Main Game Area (3 cols) -->
			<div class="lg:col-span-3 space-y-4">
				<!-- Dice + Status Bar -->
				<div class="bg-slate-800 rounded-xl border border-slate-700 p-4 flex items-center gap-6">
					<div class="flex gap-4 items-center">
						<div class="die-display" id="die1" data-value="0">
							<svg viewBox="0 0 60 60" class="w-14 h-14" aria-hidden="true">
								<rect width="60" height="60" rx="10" class="die-face"></rect>
								<g class="die-dots" id="die1-dots"></g>
							</svg>
						</div>
						<div class="die-display" id="die2" data-value="0">
							<svg viewBox="0 0 60 60" class="w-14 h-14" aria-hidden="true">
								<rect width="60" height="60" rx="10" class="die-face"></rect>
								<g class="die-dots" id="die2-dots"></g>
							</svg>
						</div>
						<div class="text-center">
							<div class="text-slate-400 text-xs uppercase tracking-wider">Total</div>
							<div class="text-3xl font-bold text-white" id="roll-total">—</div>
						</div>
					</div>

					<div class="flex-1 border-l border-slate-700 pl-4">
						<div class="flex items-center gap-3 mb-1">
							<span
								id="phase-badge"
								class="px-2 py-0.5 rounded text-xs font-bold bg-blue-500/20 text-blue-400 uppercase tracking-wider"
							>
								Come-Out
							</span>
							<span
								id="point-badge"
								class="hidden px-2 py-0.5 rounded text-xs font-bold bg-yellow-500/20 text-yellow-400"
							>
								Point: —
							</span>
						</div>
						<div id="game-message" class="text-slate-300 text-sm">Place your bets, then roll!</div>
					</div>

					<div>
						<button
							id="roll-button"
							data-testid="roll-button"
							disabled
							class="btn-gold px-6 py-3 rounded-xl font-bold text-lg disabled:opacity-40 disabled:cursor-not-allowed min-w-[110px]"
						>
							ROLL
						</button>
					</div>
				</div>

				<!-- Craps Table -->
				<div class="craps-table rounded-2xl p-4 space-y-3">
					<!-- Pass Line / Don't Pass -->
					<div class="grid grid-cols-2 gap-3">
						<div
							data-bet-type="passLine"
							class="bet-zone pass-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-white font-bold text-sm uppercase tracking-wider">Pass Line</div>
							<div class="text-slate-400 text-xs">Pays 1:1</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
						<div
							data-bet-type="dontPass"
							class="bet-zone dont-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-white font-bold text-sm uppercase tracking-wider">
								Don't Pass Bar
							</div>
							<div class="text-slate-400 text-xs">Pays 1:1 (Bar 12)</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
					</div>

					<!-- Pass Odds / Don't Pass Odds (shown only in point phase) -->
					<div id="odds-row" class="hidden grid-cols-2 gap-3">
						<div
							data-bet-type="passLineOdds"
							class="bet-zone odds-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-emerald-400 font-bold text-sm uppercase tracking-wider">
								Pass Odds
							</div>
							<div class="text-slate-400 text-xs">0% house edge · 2x max</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
						<div
							data-bet-type="dontPassOdds"
							class="bet-zone odds-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-emerald-400 font-bold text-sm uppercase tracking-wider">
								Don't Pass Odds
							</div>
							<div class="text-slate-400 text-xs">0% house edge · 2x max</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
					</div>

					<!-- Number Row: Place / Come bets per number -->
					<div class="grid grid-cols-6 gap-2">
						{
							[4, 5, 6, 8, 9, 10].map((n) => (
								<div class="number-box rounded-lg p-2 text-center" data-number={n}>
									<div class="text-white font-bold text-sm">
										{n === 6 ? 'SIX' : n === 8 ? 'EIGHT' : n}
									</div>
									<div
										data-bet-type={`place${n}`}
										class="bet-zone place-zone cursor-pointer mt-1 rounded p-1 text-center"
									>
										<div class="text-slate-400 text-xs">Place</div>
										<div class="bet-amount text-yellow-400 font-bold h-4 text-xs" />
									</div>
									<div id={`come-${n}`} class="come-bet-display mt-1 hidden">
										<div class="text-blue-300 text-xs font-bold come-display-amount" />
									</div>
									<div class="flex gap-1 mt-1 justify-center">
										<div
											data-bet-type={`buy${n}`}
											class="bet-zone buy-zone cursor-pointer rounded px-1 py-0.5 text-xs text-emerald-400 hover:bg-emerald-900/30"
										>
											B
										</div>
										<div
											data-bet-type={`lay${n}`}
											class="bet-zone lay-zone cursor-pointer rounded px-1 py-0.5 text-xs text-red-400 hover:bg-red-900/30"
										>
											L
										</div>
									</div>
								</div>
							))
						}
					</div>

					<!-- Come / Don't Come / Field -->
					<div class="grid grid-cols-3 gap-3">
						<div
							data-bet-type="come"
							class="bet-zone come-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-blue-400 font-bold text-sm uppercase tracking-wider">Come</div>
							<div class="text-slate-400 text-xs">Pays 1:1</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
						<div
							data-bet-type="field"
							class="bet-zone field-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-purple-400 font-bold text-sm uppercase tracking-wider">Field</div>
							<div class="text-slate-400 text-xs">3,4,9,10,11 · 2× on 2 · 3× on 12</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
						<div
							data-bet-type="dontCome"
							class="bet-zone dont-zone cursor-pointer select-none rounded-lg p-3 text-center transition-all"
						>
							<div class="text-orange-400 font-bold text-sm uppercase tracking-wider">
								Don't Come
							</div>
							<div class="text-slate-400 text-xs">Pays 1:1 (Bar 12)</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
					</div>

					<!-- Big 6 / Big 8 -->
					<div class="grid grid-cols-2 gap-3">
						<div
							data-bet-type="big6"
							class="bet-zone place-zone cursor-pointer select-none rounded-lg p-3 text-center"
						>
							<div class="text-slate-300 font-bold text-sm uppercase tracking-wider">Big 6</div>
							<div class="text-slate-400 text-xs">Pays 1:1</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
						<div
							data-bet-type="big8"
							class="bet-zone place-zone cursor-pointer select-none rounded-lg p-3 text-center"
						>
							<div class="text-slate-300 font-bold text-sm uppercase tracking-wider">Big 8</div>
							<div class="text-slate-400 text-xs">Pays 1:1</div>
							<div class="bet-amount text-yellow-400 font-bold mt-1 h-5 text-sm"></div>
						</div>
					</div>

					<!-- Hardways Row -->
					<div class="border-t border-slate-700/50 pt-3">
						<div class="text-slate-400 text-xs uppercase tracking-wider mb-2 text-center">
							Hardways (off during come-out)
						</div>
						<div class="grid grid-cols-4 gap-2">
							{
								[
									{ type: 'hard4', label: 'Hard 4', pays: '7:1' },
									{ type: 'hard6', label: 'Hard 6', pays: '9:1' },
									{ type: 'hard8', label: 'Hard 8', pays: '9:1' },
									{ type: 'hard10', label: 'Hard 10', pays: '7:1' },
								].map((h) => (
									<div
										data-bet-type={h.type}
										class="bet-zone hardway-zone cursor-pointer select-none rounded-lg p-2 text-center transition-all"
									>
										<div class="text-amber-400 font-bold text-xs">{h.label}</div>
										<div class="text-slate-400 text-xs">{h.pays}</div>
										<div class="bet-amount text-yellow-400 font-bold mt-1 h-4 text-xs" />
									</div>
								))
							}
						</div>
					</div>

					<!-- Proposition Bets -->
					<div class="border-t border-slate-700/50 pt-3">
						<div class="text-slate-400 text-xs uppercase tracking-wider mb-2 text-center">
							Proposition Bets (one-roll)
						</div>
						<div class="grid grid-cols-7 gap-1.5">
							{
								[
									{ type: 'any7', label: 'Any 7', pays: '4:1' },
									{ type: 'anyCraps', label: 'Any Craps', pays: '7:1' },
									{ type: 'aces', label: 'Aces (2)', pays: '30:1' },
									{ type: 'aceDeuce', label: 'Ace-Deuce', pays: '15:1' },
									{ type: 'yo', label: 'Yo (11)', pays: '15:1' },
									{ type: 'boxcars', label: 'Boxcars', pays: '30:1' },
									{ type: 'ce', label: 'C & E', pays: '3/7:1' },
								].map((p) => (
									<div
										data-bet-type={p.type}
										class="bet-zone prop-zone cursor-pointer select-none rounded-lg p-1.5 text-center transition-all"
									>
										<div class="text-red-400 font-bold text-xs leading-tight">{p.label}</div>
										<div class="text-slate-500 text-xs">{p.pays}</div>
										<div class="bet-amount text-yellow-400 font-bold mt-0.5 h-4 text-xs" />
									</div>
								))
							}
						</div>
					</div>
				</div><!-- /craps-table -->

				<!-- Chip Selection + Controls -->
				<div class="bg-slate-900 rounded-xl p-4 border border-slate-700">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<div class="flex gap-2 flex-wrap">
							{
								[
									{ amount: 5, color: 'gold' },
									{ amount: 25, color: 'red' },
									{ amount: 50, color: 'blue' },
									{ amount: 100, color: 'green' },
									{ amount: 500, color: 'black' },
								].map((c) => (
									<button
										class="chip-select hover:scale-110 transition-transform"
										data-amount={c.amount}
										data-testid={`chip-${c.amount}`}
									>
										<PokerChip
											value={c.amount}
											color={c.color as 'red' | 'blue' | 'green' | 'black' | 'gold'}
										/>
									</button>
								))
							}
						</div>
						<div class="flex items-center gap-3">
							<div>
								<span class="text-slate-400 text-sm">Total Bet:</span>
								<span id="total-bet" data-testid="total-bet" class="text-yellow-400 font-bold ml-1"
									>$0</span
								>
							</div>
							<button
								id="clear-bets-button"
								data-testid="clear-bets-button"
								class="px-3 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg text-sm transition-colors"
							>
								Clear Bets
							</button>
						</div>
					</div>
				</div>
			</div><!-- /main game area -->

			<!-- Sidebar (1 col) -->
			<div class="space-y-4">
				<!-- Roll History -->
				<div class="bg-slate-900 rounded-xl p-4 border border-slate-700">
					<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">
						Roll History
					</h3>
					<div
						id="roll-history"
						data-testid="roll-history"
						class="flex flex-wrap gap-1.5 min-h-[40px]"
					>
						<span class="text-neutral-500 text-xs">No rolls yet</span>
					</div>
				</div>

				<!-- Active Bets -->
				<div class="bg-slate-900 rounded-xl p-4 border border-slate-700">
					<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">
						Active Bets
					</h3>
					<div id="active-bets" data-testid="active-bets" class="space-y-1.5 min-h-[40px]">
						<span class="text-neutral-500 text-xs">No bets placed</span>
					</div>
				</div>

				<!-- Come Bet Odds -->
				<div
					id="come-odds-panel"
					data-testid="come-odds-panel"
					class="hidden bg-slate-900 rounded-xl p-4 border border-blue-500/20"
				>
					<h3 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-3">
						Come Bet Odds
					</h3>
					<div id="come-odds-list" data-testid="come-odds-list" class="space-y-2"></div>
					<p class="text-slate-500 text-xs mt-2">Click to add 2× odds (0% edge)</p>
				</div>

				<!-- Payouts Reference -->
				<div class="bg-slate-900 rounded-xl p-4 border border-slate-700">
					<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Payouts</h3>
					<div class="space-y-1 text-xs">
						<div class="flex justify-between">
							<span class="text-slate-300">Pass/Come</span><span class="text-slate-400">1:1</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Odds (4/10)</span><span class="text-slate-400">2:1</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Odds (5/9)</span><span class="text-slate-400">3:2</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Odds (6/8)</span><span class="text-slate-400">6:5</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Place 6/8</span><span class="text-slate-400">7:6</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Place 5/9</span><span class="text-slate-400">7:5</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Place 4/10</span><span class="text-slate-400">9:5</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Hard 6/8</span><span class="text-slate-400">9:1</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Hard 4/10</span><span class="text-slate-400">7:1</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Any 7</span><span class="text-slate-400">4:1</span>
						</div>
						<div class="flex justify-between">
							<span class="text-slate-300">Yo (11)</span><span class="text-slate-400">15:1</span>
						</div>
					</div>
				</div>

				<!-- LLM Advisor -->
				<div class="bg-slate-900 rounded-xl p-4 border border-slate-700">
					<div class="flex items-center justify-between mb-3">
						<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">AI Advisor</h3>
						<button
							id="llm-advice-btn"
							data-testid="llm-advice-btn"
							class="px-3 py-1 bg-yellow-600/20 hover:bg-yellow-600/40 text-yellow-400 rounded text-xs transition-colors border border-yellow-500/30"
						>
							Ask
						</button>
					</div>
					<div id="llm-advice" class="text-slate-400 text-xs leading-relaxed min-h-[48px]">
						Configure AI in your profile, then ask for advice.
					</div>
				</div>
			</div><!-- /sidebar -->
		</div><!-- /grid -->

		<!-- Insufficient Chips Overlay -->
		<div
			id="insufficient-overlay"
			class="fixed inset-0 bg-slate-900/95 backdrop-blur-sm z-50 items-center justify-center hidden"
		>
			<div class="bg-slate-800 rounded-xl p-8 border border-red-500/50 max-w-md text-center">
				<div class="text-5xl mb-4">💸</div>
				<h2 class="text-2xl font-bold text-white mb-2">Insufficient Chips</h2>
				<p class="text-slate-400 mb-6">You don't have enough chips to continue.</p>
				<a href="/games" class="btn-gold px-8 py-3 rounded-lg font-bold inline-block"
					>Return to Lobby</a
				>
			</div>
		</div>

		<!-- Achievement Toast -->
		<div
			id="achievement-toast"
			data-testid="achievement-toast"
			role="status"
			aria-live="polite"
			aria-atomic="true"
			class="fixed bottom-4 right-4 bg-gradient-to-r from-yellow-500 to-amber-500 text-slate-900 px-5 py-4 rounded-xl shadow-2xl flex items-center gap-3 transition-all duration-300 opacity-0 pointer-events-none translate-y-4"
			style="z-index: 9999;"
		>
			<span id="achievement-icon" data-testid="achievement-icon" class="text-3xl">🏆</span>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider opacity-80">
					Achievement Unlocked
				</p>
				<p id="achievement-name" data-testid="achievement-name" class="font-bold text-lg">
					Achievement Name
				</p>
			</div>
		</div>
	</div><!-- /craps-root -->
</CasinoLayout>

<style>
	.craps-table {
		background: linear-gradient(135deg, #0a3d28 0%, #073020 50%, #052518 100%);
		box-shadow:
			inset 0 0 80px rgba(0, 0, 0, 0.3),
			0 8px 32px rgba(0, 0, 0, 0.5);
	}

	.bet-zone {
		border: 2px solid rgba(255, 255, 255, 0.08);
		transition: all 0.15s ease;
	}
	.bet-zone:hover {
		border-color: rgba(234, 179, 8, 0.5);
		background: rgba(234, 179, 8, 0.05);
		transform: translateY(-1px);
	}
	.bet-zone:focus-visible {
		outline: 2px solid rgba(234, 179, 8, 0.9);
		outline-offset: 2px;
	}
	.bet-zone-active {
		border-color: rgba(234, 179, 8, 0.8) !important;
		box-shadow: 0 0 12px rgba(234, 179, 8, 0.25);
	}
	.bet-zone-locked {
		opacity: 0.6;
		cursor: not-allowed !important;
		pointer-events: none;
	}
	.bet-zone-disabled {
		opacity: 0.35;
		cursor: not-allowed !important;
		pointer-events: none;
	}

	.pass-zone {
		background: rgba(59, 130, 246, 0.08);
	}
	.dont-zone {
		background: rgba(239, 68, 68, 0.08);
	}
	.odds-zone {
		background: rgba(16, 185, 129, 0.08);
	}
	.come-zone {
		background: rgba(96, 165, 250, 0.08);
	}
	.field-zone {
		background: rgba(168, 85, 247, 0.08);
	}
	.place-zone {
		background: rgba(245, 158, 11, 0.08);
	}
	.hardway-zone {
		background: rgba(251, 191, 36, 0.08);
	}
	.prop-zone {
		background: rgba(239, 68, 68, 0.08);
	}
	.buy-zone {
		background: rgba(16, 185, 129, 0.1);
	}
	.lay-zone {
		background: rgba(239, 68, 68, 0.1);
	}

	.number-box {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.number-box-point {
		border-color: rgba(234, 179, 8, 0.6) !important;
		box-shadow: 0 0 16px rgba(234, 179, 8, 0.2);
	}

	.die-face {
		fill: #f8fafc;
	}
	.die-dot {
		fill: #1e293b;
	}
	.die-display {
		filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.4));
		transition: transform 0.15s ease;
	}
	.die-rolling {
		animation: diceRoll 0.4s ease-out;
	}
	@keyframes diceRoll {
		0% {
			transform: rotate(0deg) scale(1);
		}
		25% {
			transform: rotate(15deg) scale(1.1);
		}
		50% {
			transform: rotate(-10deg) scale(0.95);
		}
		75% {
			transform: rotate(5deg) scale(1.05);
		}
		100% {
			transform: rotate(0deg) scale(1);
		}
	}

	.roll-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		font-size: 11px;
		font-weight: bold;
	}
	.roll-natural {
		background: #166534;
		color: #86efac;
	}
	.roll-craps {
		background: #7f1d1d;
		color: #fca5a5;
	}
	.roll-point {
		background: #1e3a5f;
		color: #93c5fd;
	}
	.roll-normal {
		background: #1e293b;
		color: #94a3b8;
	}
	.roll-seven {
		background: #7c2d12;
		color: #fdba74;
	}

	.chip-select {
		transition: transform 0.15s ease;
	}
	.chip-select.selected {
		transform: scale(1.2);
		filter: drop-shadow(0 0 8px rgba(234, 179, 8, 0.5));
	}
</style>

<script>
	import { CrapsGame } from '../../lib/craps/CrapsGame';
	import { BET_LABELS } from '../../lib/craps/constants';
	import type { BetType, RollResult, CrapsBet } from '../../lib/craps/types';
	import { initAchievementToast } from '../../lib/achievement-toast';

	// ─── Initialisation ─────────────────────────────────────────────────────────
	if (typeof window !== 'undefined') {
		const root = document.getElementById('craps-root');
		if (!root) throw new Error('craps-root not found');
		const initialBalance = Number(root.dataset.initialBalance ?? 1000);

		const game = new CrapsGame({
			initialBalance,
			settings: { minBet: 5, maxBet: 500, maxOddsMultiplier: 2 },
		});

		let selectedChipAmount = 25;
		let lastSyncedBalance = initialBalance;
		let isSyncInProgress = false;
		let syncPending = false;
		let pendingRetryScheduled = false;
		let pendingWins = 0;
		let pendingLosses = 0;
		let pendingHands = 0;
		let retryDelayMs = 100; // Base retry delay, doubles on network failure (max 30s)
		let diceAnimationTimeoutId: ReturnType<typeof setTimeout> | null = null;

		// ─── DOM helpers ─────────────────────────────────────────────────────────────

		function el<T extends HTMLElement>(id: string): T {
			const e = document.getElementById(id);
			if (!e) throw new Error(`#${id} not found`);
			return e as T;
		}

		const balanceEl = el('chip-balance');
		const totalBetEl = el('total-bet');
		const rollButton = el<HTMLButtonElement>('roll-button');
		const clearBetsBtn = el('clear-bets-button');
		const gameMessageEl = el('game-message');
		const phaseBadge = el('phase-badge');
		const pointBadge = el('point-badge');
		const oddsRow = el('odds-row');
		const rollTotalEl = el('roll-total');
		const rollHistoryEl = el<HTMLElement>('roll-history');
		const activeBetsEl = el('active-bets');
		const insufOverlay = el('insufficient-overlay');
		const llmAdviceEl = el('llm-advice');
		const llmAdviceBtn = el<HTMLButtonElement>('llm-advice-btn');
		const comeOddsPanel = el('come-odds-panel');
		const comeOddsListEl = el('come-odds-list');

		function initializeInteractiveBetZones() {
			document.querySelectorAll('.bet-zone[data-bet-type]').forEach((el) => {
				const zone = el as HTMLElement;
				const type = zone.dataset.betType as BetType | undefined;
				if (!type) return;
				zone.dataset.testid = `bet-${type}`;
				zone.setAttribute('role', 'button');
				zone.tabIndex = 0;
				zone.setAttribute('aria-label', `Place ${BET_LABELS[type] ?? type} bet`);
			});

			document.querySelectorAll('.number-box').forEach((el) => {
				const box = el as HTMLElement;
				const n = box.dataset.number;
				if (n) box.setAttribute('aria-label', `Number ${n} betting box`);
			});

			[4, 5, 6, 8, 9, 10].forEach((n) => {
				const comeDisplay = document.getElementById(`come-${n}`);
				if (comeDisplay) comeDisplay.setAttribute('aria-label', `Come bets on ${n}`);
			});
		}

		// ─── Die face SVG dots ────────────────────────────────────────────────────────

		// cx,cy pairs for dot positions on a 60×60 die
		const DOT_POSITIONS: Record<number, [number, number][]> = {
			1: [[30, 30]],
			2: [
				[18, 18],
				[42, 42],
			],
			3: [
				[18, 18],
				[30, 30],
				[42, 42],
			],
			4: [
				[18, 18],
				[42, 18],
				[18, 42],
				[42, 42],
			],
			5: [
				[18, 18],
				[42, 18],
				[30, 30],
				[18, 42],
				[42, 42],
			],
			6: [
				[18, 15],
				[42, 15],
				[18, 30],
				[42, 30],
				[18, 45],
				[42, 45],
			],
		};

		function renderDie(dotsEl: Element, value: number) {
			dotsEl.innerHTML = '';
			const positions = DOT_POSITIONS[value] ?? [];
			for (const [cx, cy] of positions) {
				const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
				circle.setAttribute('cx', String(cx));
				circle.setAttribute('cy', String(cy));
				circle.setAttribute('r', '5');
				circle.setAttribute('class', 'die-dot');
				dotsEl.appendChild(circle);
			}
		}

		function animateDice(die1: number, die2: number) {
			const d1 = document.getElementById('die1');
			const d2 = document.getElementById('die2');
			[d1, d2].forEach((d) => d?.classList.add('die-rolling'));
			if (diceAnimationTimeoutId) {
				clearTimeout(diceAnimationTimeoutId);
			}
			diceAnimationTimeoutId = setTimeout(() => {
				[d1, d2].forEach((d) => d?.classList.remove('die-rolling'));
				const d1Dots = document.getElementById('die1-dots');
				const d2Dots = document.getElementById('die2-dots');
				if (d1Dots) renderDie(d1Dots, die1);
				if (d2Dots) renderDie(d2Dots, die2);
				rollTotalEl.textContent = String(die1 + die2);
				diceAnimationTimeoutId = null;
			}, 420);
		}

		// ─── UI update ───────────────────────────────────────────────────────────────

		function updateUI() {
			const state = game.getState();

			// Balance
			balanceEl.textContent = `$${state.chipBalance.toLocaleString()}`;

			// Total bet
			const total = game.getTotalAtRisk();
			totalBetEl.textContent = `$${total}`;

			// Roll button
			rollButton.disabled = !game.canRoll();

			// Phase badge
			if (state.phase === 'come-out') {
				phaseBadge.textContent = 'Come-Out';
				phaseBadge.className =
					'px-2 py-0.5 rounded text-xs font-bold bg-blue-500/20 text-blue-400 uppercase tracking-wider';
				pointBadge.classList.add('hidden');
				oddsRow.classList.add('hidden');
				oddsRow.style.removeProperty('display');
			} else {
				phaseBadge.textContent = 'Point Phase';
				phaseBadge.className =
					'px-2 py-0.5 rounded text-xs font-bold bg-yellow-500/20 text-yellow-400 uppercase tracking-wider';
				pointBadge.textContent = `Point: ${state.point}`;
				pointBadge.classList.remove('hidden');
				oddsRow.classList.remove('hidden');
				oddsRow.style.display = 'grid';
			}

			// Highlight the point number box
			document.querySelectorAll('.number-box').forEach((box) => {
				const n = Number((box as HTMLElement).dataset.number);
				box.classList.toggle('number-box-point', state.phase === 'point' && n === state.point);
			});

			// Bet zone amounts
			document.querySelectorAll('[data-bet-type]').forEach((zone) => {
				const type = (zone as HTMLElement).dataset.betType as BetType;
				const amountEl = zone.querySelector('.bet-amount');
				if (!amountEl) return;

				// For passLineOdds/dontPassOdds, show the odds on the line bet
				if (type === 'passLineOdds') {
					const lineBet = state.activeBets.find((b) => b.type === 'passLine');
					const odds = lineBet?.odds ?? 0;
					amountEl.textContent = odds > 0 ? `$${odds}` : '';
				} else if (type === 'dontPassOdds') {
					const lineBet = state.activeBets.find((b) => b.type === 'dontPass');
					const odds = lineBet?.odds ?? 0;
					amountEl.textContent = odds > 0 ? `$${odds}` : '';
				} else {
					const bet = state.activeBets.find((b) => b.type === type && !b.point);
					amountEl.textContent = bet ? `$${bet.amount}` : '';
				}

				// Active glow
				const hasBet =
					type === 'passLineOdds'
						? (state.activeBets.find((b) => b.type === 'passLine')?.odds ?? 0) > 0
						: type === 'dontPassOdds'
							? (state.activeBets.find((b) => b.type === 'dontPass')?.odds ?? 0) > 0
							: state.activeBets.some((b) => b.type === type && !b.point);
				zone.classList.toggle('bet-zone-active', hasBet);
			});

			// Phase-based bet zone restrictions
			applyPhaseRestrictions(state.phase);
			document.querySelectorAll('.bet-zone').forEach((el) => {
				const zone = el as HTMLElement;
				const disabled =
					zone.classList.contains('bet-zone-disabled') ||
					zone.classList.contains('bet-zone-locked');
				zone.setAttribute('aria-disabled', String(disabled));
			});

			// Come bets on number boxes
			[4, 5, 6, 8, 9, 10].forEach((n) => {
				const container = document.getElementById(`come-${n}`);
				if (!container) return;
				const comeBets = state.activeBets.filter(
					(b) => (b.type === 'come' || b.type === 'dontCome') && b.point === n,
				);
				if (comeBets.length > 0) {
					container.classList.remove('hidden');
					const totalAmount = comeBets.reduce((s, b) => s + b.amount + (b.odds ?? 0), 0);
					const amtEl = container.querySelector('.come-display-amount');
					if (amtEl) amtEl.textContent = `$${totalAmount}`;
				} else {
					container.classList.add('hidden');
				}
			});

			// Come odds panel
			const establishedComeBets = state.activeBets.filter(
				(b) => (b.type === 'come' || b.type === 'dontCome') && b.point,
			);
			if (establishedComeBets.length > 0 && state.phase === 'point') {
				comeOddsPanel.classList.remove('hidden');
				renderComeOddsButtons(establishedComeBets);
			} else {
				comeOddsPanel.classList.add('hidden');
			}

			// Active bets list
			renderActiveBets(state.activeBets);
		}

		function applyPhaseRestrictions(phase: 'come-out' | 'point') {
			// Come/DontCome only during point phase
			['come', 'dontCome'].forEach((t) => {
				document
					.querySelector(`[data-bet-type="${t}"]`)
					?.classList.toggle('bet-zone-disabled', phase !== 'point');
			});
			// PassLine/DontPass only during come-out
			['passLine', 'dontPass'].forEach((t) => {
				const alreadyBet = game.getState().activeBets.some((b) => b.type === t);
				const zone = document.querySelector(`[data-bet-type="${t}"]`);
				if (!zone) return;
				if (alreadyBet && phase === 'point') {
					zone.classList.add('bet-zone-locked');
					zone.classList.remove('bet-zone-disabled');
				} else if (phase === 'point' && !alreadyBet) {
					zone.classList.add('bet-zone-disabled');
				} else {
					zone.classList.remove('bet-zone-locked', 'bet-zone-disabled');
				}
			});
		}

		function renderActiveBets(bets: CrapsBet[]) {
			if (bets.length === 0) {
				activeBetsEl.innerHTML = '<span class="text-neutral-500 text-xs">No bets placed</span>';
				return;
			}
			activeBetsEl.innerHTML = '';
			for (const bet of bets) {
				const label = BET_LABELS[bet.type] ?? bet.type;
				const pointStr = bet.point ? ` @${bet.point}` : '';
				const oddsStr = bet.odds ? ` +odds:$${bet.odds}` : '';

				const row = document.createElement('div');
				row.className = 'flex items-center justify-between text-xs';
				row.innerHTML = `
				<span class="text-slate-300">${label}${pointStr}</span>
				<span class="text-yellow-400 font-bold">$${bet.amount}${oddsStr}</span>
			`;
				activeBetsEl.appendChild(row);
			}
		}

		function renderComeOddsButtons(bets: CrapsBet[]) {
			comeOddsListEl.innerHTML = '';
			for (const bet of bets) {
				const label = `${bet.type === 'come' ? 'Come' : "Don't Come"} @${bet.point}`;
				const maxOdds = bet.amount * 2;
				const currentOdds = bet.odds ?? 0;
				const remaining = maxOdds - currentOdds;
				if (remaining <= 0) continue;

				const row = document.createElement('div');
				row.className = 'flex items-center justify-between gap-2';
				row.innerHTML = `
				<span class="text-slate-300 text-xs flex-1">${label} ($${currentOdds}/$${maxOdds})</span>
				<button class="add-come-odds px-2 py-1 text-xs bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-400 border border-emerald-500/30 rounded" data-bet-id="${bet.id}" data-amount="${Math.min(selectedChipAmount, remaining)}">
					+$${Math.min(selectedChipAmount, remaining)}
				</button>
			`;
				comeOddsListEl.appendChild(row);
			}

			comeOddsListEl.querySelectorAll('.add-come-odds').forEach((btn) => {
				btn.addEventListener('click', () => {
					const betId = (btn as HTMLElement).dataset.betId!;
					const amount = Number((btn as HTMLElement).dataset.amount);
					const r = game.addComeBetOdds(betId, amount);
					if (!r.success) showMessage(r.error ?? 'Cannot add odds', 'error');
					updateUI();
				});
			});
		}

		// ─── Roll history ─────────────────────────────────────────────────────────────

		function addRollToHistory(total: number, prevPhase: 'come-out' | 'point') {
			// Remove "no rolls" placeholder
			const placeholder = rollHistoryEl.querySelector('span');
			if (placeholder) placeholder.remove();

			const badge = document.createElement('span');
			badge.className = 'roll-badge';
			badge.textContent = String(total);

			if (prevPhase === 'come-out') {
				if (total === 7 || total === 11) badge.className += ' roll-natural';
				else if (total === 2 || total === 3 || total === 12) badge.className += ' roll-craps';
				else badge.className += ' roll-point';
			} else {
				if (total === 7) badge.className += ' roll-seven';
				else badge.className += ' roll-normal';
			}

			rollHistoryEl.insertBefore(badge, rollHistoryEl.firstChild);

			// Keep last 15 badges
			const badges = rollHistoryEl.querySelectorAll('.roll-badge');
			if (badges.length > 15) badges[badges.length - 1].remove();
		}

		// ─── Roll result display ─────────────────────────────────────────────────────

		function showRollResult(result: RollResult) {
			// Show outcome in message area
			let msgClass = 'text-slate-300';
			if (
				result.message.includes('wins') ||
				result.message.includes('made') ||
				result.message.includes('Natural') ||
				result.message.includes('Yo-Eleven')
			) {
				msgClass = 'text-green-400';
			} else if (
				result.message.includes('loses') ||
				result.message.includes('out') ||
				result.message.includes('Craps')
			) {
				msgClass = 'text-red-400';
			}
			gameMessageEl.className = `text-sm font-semibold ${msgClass}`;
			gameMessageEl.textContent = result.message;

			// Show net delta
			if (result.netDelta !== 0) {
				const sign = result.netDelta > 0 ? '+' : '';
				const deltaEl = document.createElement('span');
				deltaEl.className = `ml-2 text-xs ${result.netDelta > 0 ? 'text-green-400' : 'text-red-400'}`;
				deltaEl.textContent = `(${sign}$${result.netDelta})`;
				gameMessageEl.appendChild(deltaEl);
			}
		}

		function showMessage(msg: string, type: 'info' | 'error' = 'info') {
			gameMessageEl.className = `text-sm ${type === 'error' ? 'text-red-400' : 'text-slate-300'}`;
			gameMessageEl.textContent = msg;
		}

		// ─── Event listeners ─────────────────────────────────────────────────────────

		// Chip selection
		document.querySelectorAll('.chip-select').forEach((btn) => {
			btn.addEventListener('click', () => {
				document.querySelectorAll('.chip-select').forEach((b) => b.classList.remove('selected'));
				btn.classList.add('selected');
				selectedChipAmount = Number((btn as HTMLElement).dataset.amount);
			});
		});
		document.querySelector('.chip-select[data-amount="25"]')?.classList.add('selected');

		function placeBetFromZone(zone: HTMLElement) {
			if (
				zone.classList.contains('bet-zone-disabled') ||
				zone.classList.contains('bet-zone-locked')
			) {
				return;
			}
			const type = zone.dataset.betType as BetType;
			const r = game.placeBet(type, selectedChipAmount);
			if (r.success) {
				updateUI();
			} else {
				showMessage(r.error ?? 'Cannot place bet', 'error');
			}
		}

		// Bet zone clicks + keyboard activation
		document.querySelectorAll<HTMLElement>('[data-bet-type]').forEach((zone) => {
			zone.addEventListener('click', () => {
				placeBetFromZone(zone);
			});
			zone.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					placeBetFromZone(zone);
				}
			});
		});

		// Roll button
		rollButton.addEventListener('click', async () => {
			rollButton.disabled = true;
			const prevPhase = game.getState().phase;

			// Animate dice first
			const tempDie1 = Math.ceil(Math.random() * 6);
			const tempDie2 = Math.ceil(Math.random() * 6);
			animateDice(tempDie1, tempDie2);

			await new Promise((r) => setTimeout(r, 200));

			const result = game.roll();
			if (!result) {
				rollButton.disabled = false;
				return;
			}

			// Update dice display with real values
			if (diceAnimationTimeoutId) {
				clearTimeout(diceAnimationTimeoutId);
				diceAnimationTimeoutId = null;
			}
			document.getElementById('die1')?.classList.remove('die-rolling');
			document.getElementById('die2')?.classList.remove('die-rolling');
			const d1Dots = document.getElementById('die1-dots');
			const d2Dots = document.getElementById('die2-dots');
			if (d1Dots) renderDie(d1Dots, result.roll.die1);
			if (d2Dots) renderDie(d2Dots, result.roll.die2);
			rollTotalEl.textContent = String(result.roll.total);

			showRollResult(result);
			addRollToHistory(result.roll.total, prevPhase);
			updateUI();

			// Track stats
			if (result.netDelta > 0) pendingWins++;
			else if (result.netDelta < 0) pendingLosses++;
			pendingHands++;

			// Sync balance after roll
			await syncBalance();

			if (game.hasInsufficientChips()) {
				insufOverlay.classList.remove('hidden');
				insufOverlay.classList.add('flex');
			}
		});

		// Clear bets
		clearBetsBtn.addEventListener('click', () => {
			game.clearBets();
			updateUI();
		});

		// LLM Advisor
		llmAdviceBtn.addEventListener('click', async () => {
			llmAdviceBtn.disabled = true;
			llmAdviceBtn.textContent = '...';
			llmAdviceEl.textContent = 'Thinking...';

			try {
				const state = game.getState();
				const adviceRes = await fetch('/api/craps-advice', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						phase: state.phase,
						point: state.point,
						activeBets: state.activeBets,
						rollHistory: state.rollHistory,
						chipBalance: state.chipBalance,
					}),
				});

				const data = (await adviceRes.json().catch(() => ({}))) as {
					advice?: string;
					error?: string;
				};

				if (!adviceRes.ok) {
					throw new Error(data.error ?? 'Failed to load advice');
				}

				llmAdviceEl.textContent = data.advice ?? 'No advice returned.';
			} catch (e) {
				llmAdviceEl.textContent = `Error: ${e instanceof Error ? e.message : 'Unknown error'}`;
			} finally {
				llmAdviceBtn.disabled = false;
				llmAdviceBtn.textContent = 'Ask';
			}
		});

		// ─── Balance sync ─────────────────────────────────────────────────────────────

		async function syncBalance() {
			if (isSyncInProgress) {
				syncPending = true;
				return;
			}

			const ackWins = pendingWins;
			const ackLosses = pendingLosses;
			const ackHands = pendingHands;
			const ackPreviousBalance = lastSyncedBalance;
			const ackCurrentBalance = game.getBalance();
			const ackDelta = ackCurrentBalance - ackPreviousBalance;
			const hasPendingStats = ackHands > 0 || ackWins > 0 || ackLosses > 0;
			if (ackDelta === 0 && !hasPendingStats) {
				syncPending = false;
				return;
			}

			const outcome: 'win' | 'loss' | 'push' =
				ackDelta > 0
					? 'win'
					: ackDelta < 0
						? 'loss'
						: ackWins > 0 && ackLosses === 0
							? 'win'
							: ackLosses > 0 && ackWins === 0
								? 'loss'
								: 'push';

			isSyncInProgress = true;

			try {
				const response = await fetch('/api/chips/update', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						delta: ackDelta,
						gameType: 'craps',
						previousBalance: ackPreviousBalance,
						outcome,
						handCount: ackHands > 0 ? ackHands : 1,
						winsIncrement: ackWins,
						lossesIncrement: ackLosses,
					}),
				});

				if (response.ok) {
					const data = (await response.json().catch(() => ({}))) as {
						balance?: number;
						newAchievements?: Array<{ id: string; name: string; icon: string }>;
					};
					// Apply server-authoritative balance to client game state and UI
					if (typeof data.balance === 'number') {
						game.setBalance(data.balance);
						lastSyncedBalance = data.balance;
						balanceEl.textContent = `$${data.balance.toLocaleString()}`;
					} else {
						lastSyncedBalance = ackPreviousBalance + ackDelta;
					}
					pendingWins = Math.max(0, pendingWins - ackWins);
					pendingLosses = Math.max(0, pendingLosses - ackLosses);
					pendingHands = Math.max(0, pendingHands - ackHands);
					syncPending = pendingWins > 0 || pendingLosses > 0 || pendingHands > 0;

					if (data.newAchievements?.length) {
						window.dispatchEvent(
							new CustomEvent('achievement-earned', {
								detail: { achievements: data.newAchievements },
							}),
						);
					}
				} else {
					const err = (await response.json().catch(() => ({}))) as {
						error?: string;
						currentBalance?: number;
					};
					if (err.error === 'RATE_LIMITED') {
						syncPending = true;
						if (!pendingRetryScheduled) {
							pendingRetryScheduled = true;
							setTimeout(() => {
								pendingRetryScheduled = false;
								void syncBalance();
							}, 2500);
						}
					} else if (typeof err.currentBalance === 'number') {
						game.applyServerBalance(err.currentBalance);
						lastSyncedBalance = err.currentBalance;
						updateUI();
					}
				}
			} catch {
				// Network error — implement exponential backoff (max 30s)
				retryDelayMs = Math.min(retryDelayMs * 2, 30000);
				if (!pendingRetryScheduled) {
					pendingRetryScheduled = true;
					setTimeout(() => {
						pendingRetryScheduled = false;
						void syncBalance();
					}, retryDelayMs);
				}
			} finally {
				isSyncInProgress = false;
				const hasRemainingPendingStats = pendingWins > 0 || pendingLosses > 0 || pendingHands > 0;
				// Reset retry delay on successful sync and trigger follow-up if needed
				if (syncPending || hasRemainingPendingStats) {
					retryDelayMs = 100;
				}
				if ((syncPending || hasRemainingPendingStats) && !pendingRetryScheduled) {
					setTimeout(() => {
						void syncBalance();
					}, retryDelayMs);
				}
			}
		}

		// ─── Achievement toast ───────────────────────────────────────────────────────

		const achievementToast = document.getElementById('achievement-toast');
		const achievementIconEl = document.getElementById('achievement-icon');
		const achievementNameEl = document.getElementById('achievement-name');

		if (achievementToast && achievementIconEl && achievementNameEl) {
			const { enqueue } = initAchievementToast(() => ({
				toast: achievementToast,
				icon: achievementIconEl,
				name: achievementNameEl,
			}));

			window.addEventListener('achievement-earned', (event: Event) => {
				const { achievements } = (
					event as CustomEvent<{ achievements: Array<{ id: string; name: string; icon: string }> }>
				).detail;
				enqueue(achievements);
			});
		}

		// ─── Initial render ───────────────────────────────────────────────────────────

		initializeInteractiveBetZones();
		updateUI();
	}
</script>
