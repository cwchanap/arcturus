---
import GameEmblem from './GameEmblem.astro';
import DecoIcon from './DecoIcon.astro';

interface Props {
	name: string;
	emblem: 'cards' | 'dice' | 'wheel' | 'spark';
	players: number;
	minBet: number;
	href: string;
	featured?: boolean;
}

const { name, emblem, players, minBet, href, featured = false } = Astro.props;
const formattedPlayers = new Intl.NumberFormat('en-US').format(players);
---

<a href={href} class="deco-card group block">
	{
		featured && (
			<div class="absolute top-3 right-3 z-10">
				<span class="deco-badge">Featured</span>
			</div>
		)
	}

	<div class="deco-emblem-frame relative h-44 border-b border-[var(--deco-brass)]/20">
		<GameEmblem
			kind={emblem}
			size={84}
			class="transition-transform duration-300 group-hover:scale-110"
		/>
	</div>

	<div class="p-6">
		<h3 class="deco-section-title mb-3 text-xl">{name}</h3>

		<div class="mb-5 flex items-center gap-5 text-sm" style="color: var(--deco-ivory-dim)">
			<span class="flex items-center gap-1.5">
				<DecoIcon name="user" size={15} class="text-[var(--deco-brass)]" />
				<span class="tabular-nums">{formattedPlayers} playing</span>
			</span>
			<span class="flex items-center gap-1.5">
				<DecoIcon name="chip" size={15} class="text-[var(--deco-brass)]" />
				<span class="tabular-nums">Min {minBet}</span>
			</span>
		</div>

		<span class="deco-btn deco-btn-primary w-full cursor-inherit">Play</span>
	</div>
</a>
