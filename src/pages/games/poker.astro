---
import CasinoLayout from '../../layouts/casino.astro';
import PokerChip from '../../components/PokerChip.astro';
import PokerCardContainer from '../../components/PokerCardContainer.astro';
import { createPublicGameSession } from '../../lib/public-game-session';

const user = Astro.locals.user;
const gameSession = createPublicGameSession(user);
const initialBalance = gameSession.initialBalance;
const hasInitialBalance = gameSession.balanceAvailableValue === 'true';
const initialBalanceLabel = hasInitialBalance
	? `$${initialBalance.toLocaleString()}`
	: 'Unavailable';
// Opaque per-user surrogate: 'anonymous' for guests, a non-reversible hash for
// authenticated users. The raw account id is never rendered into the DOM.
const clientUserId = gameSession.clientUserId;
---

<CasinoLayout title="Texas Hold'em Poker - Arcturus Casino">
	<div
		id="poker-root"
		data-guest-mode={gameSession.guestModeValue}
		class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
	>
		<!-- Game Header -->
		<div class="flex items-center justify-between mb-8">
			<div>
				<a
					href="/#games"
					class="text-[var(--deco-muted)] hover:text-[var(--deco-brass)] transition-colors mb-2 inline-block"
				>
					← Back to Games
				</a>
				<h1 class="deco-section-title text-4xl">Texas Hold'em Poker</h1>
			</div>
			<div class="flex items-center gap-4">
				<div
					class="bg-[var(--deco-obsidian-2)] px-6 py-3 rounded-lg border border-[var(--deco-brass-dim)]"
				>
					<div class="text-xs text-[var(--deco-muted)] mb-1">{gameSession.balanceLabel}</div>
					<div
						class="text-2xl font-bold text-[var(--deco-brass)]"
						id="player-balance"
						data-testid="player-balance"
						data-balance={hasInitialBalance ? String(initialBalance) : ''}
						data-balance-available={gameSession.balanceAvailableValue}
						data-guest-mode={gameSession.guestModeValue}
						data-user-id={clientUserId}
					>
						{initialBalanceLabel}
					</div>
				</div>
			</div>
		</div>

		<!-- Poker Table -->
		<div class="felt-table p-6 md:p-8 mb-6 relative" style="min-height: 580px;">
			<!-- Pot Display - Top Center -->
			<div class="absolute top-6 left-1/2 -translate-x-1/2 z-10">
				<div
					class="bg-[var(--deco-obsidian-2)] backdrop-blur-sm px-5 py-2.5 rounded-full border-2 border-[var(--deco-brass)] shadow-lg"
				>
					<div class="text-xs text-[var(--deco-muted)] text-center mb-0.5">POT</div>
					<div class="text-xl font-bold text-[var(--deco-brass)]" id="pot-amount">$0</div>
				</div>
			</div>

			<!-- Community Cards - Center -->
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -mt-4">
				<PokerCardContainer
					id="community-cards"
					maxCards={5}
					size="community"
					showPlaceholders={true}
					placeholderText="?"
				/>
			</div>

			<!-- LLM Configuration Overlay -->
			<div
				id="llm-overlay"
				class="hidden absolute inset-0 z-40 bg-[var(--deco-obsidian)] backdrop-blur-sm flex items-center justify-center rounded-[50%/38%]"
			>
				<div
					class="max-w-md w-full mx-4 bg-[var(--deco-obsidian-2)] border border-[var(--deco-line)] rounded-2xl p-6 shadow-2xl flex flex-col gap-3"
				>
					<div class="flex items-center gap-3">
						<div
							class="h-10 w-10 flex items-center justify-center rounded-xl bg-[var(--deco-obsidian-2)] text-[var(--deco-brass)]"
						>
							⚠️
						</div>
						<div>
							<h2 class="text-lg font-semibold text-[var(--deco-ivory)]">
								LLM Poker Rival not configured
							</h2>
							<p class="text-xs text-[var(--deco-muted)]">
								LLM-powered AI is enabled in your game settings, but no API key is configured.
							</p>
						</div>
					</div>
					<p class="text-sm text-[var(--deco-ivory-dim)]">
						Add an OpenAI or Gemini API key in your profile to unlock AI-powered poker rivals. You
						can also disable the LLM option in Game Settings to play with built-in AI only.
					</p>
					<div class="flex flex-wrap gap-2 mt-2">
						<a
							href="/profile"
							class="inline-flex items-center justify-center gap-2 rounded-lg bg-[var(--deco-brass)] px-4 py-2 text-sm font-semibold text-[var(--deco-obsidian)] hover:bg-[var(--deco-brass-bright)] transition"
						>
							Configure API Key
						</a>
						<button
							id="llm-overlay-close"
							type="button"
							class="inline-flex items-center justify-center gap-2 rounded-lg bg-[var(--deco-obsidian-2)] px-4 py-2 text-xs font-semibold text-[var(--deco-ivory-dim)] hover:bg-[var(--deco-obsidian-3)] border border-[var(--deco-line)] transition"
						>
							Play without LLM
						</button>
					</div>
				</div>
			</div>

			<!-- Opponents - Arc positioning around oval table -->
			<!-- Opponent 1: Top-Left (10 o'clock position) -->
			<div class="absolute top-16 left-6 md:left-12">
				<div
					class="bg-[var(--deco-obsidian-2)] backdrop-blur-sm p-2.5 md:p-3 rounded-lg border border-[var(--deco-line)] shadow-lg"
				>
					<div class="text-xs text-[var(--deco-ivory-dim)] mb-1.5 font-medium">Player 2</div>
					<PokerCardContainer
						id="opponent1-cards"
						maxCards={2}
						size="small"
						showPlaceholders={false}
					/>
					<div class="text-xs text-[var(--deco-brass)] font-semibold" id="opponent1-chips">
						$500
					</div>
				</div>
			</div>

			<!-- Opponent 2: Top-Right (2 o'clock position) -->
			<div class="absolute top-16 right-6 md:right-12">
				<div
					class="bg-[var(--deco-obsidian-2)] backdrop-blur-sm p-2.5 md:p-3 rounded-lg border border-[var(--deco-line)] shadow-lg"
				>
					<div class="text-xs text-[var(--deco-ivory-dim)] mb-1.5 font-medium">Player 3</div>
					<PokerCardContainer
						id="opponent2-cards"
						maxCards={2}
						size="small"
						showPlaceholders={false}
					/>
					<div class="text-xs text-[var(--deco-brass)] font-semibold" id="opponent2-chips">
						$750
					</div>
				</div>
			</div>

			<!-- Player's Hand with Integrated Controls -->
			<div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 w-full max-w-xl px-3">
				<div
					class="bg-[var(--deco-obsidian-2)] backdrop-blur-sm p-4 md:p-5 rounded-xl border-2 border-[var(--deco-brass-dim)] player-area-glow"
				>
					<!-- Hand Display -->
					<div class="text-center mb-3">
						<div class="text-xs text-[var(--deco-muted)] mb-0.5">Your Hand</div>
						<div class="text-base md:text-lg font-bold text-[var(--deco-brass)]" id="hand-strength">
							--
						</div>
					</div>
					<div class="flex gap-2 md:gap-3 justify-center mb-3">
						<PokerCardContainer
							id="player-cards"
							maxCards={2}
							size="normal"
							showPlaceholders={false}
						/>
					</div>

					<!-- Integrated Betting Controls -->
					<div class="border-t border-[var(--deco-line)] pt-3 space-y-2.5">
						<!-- Action Buttons Row -->
						<div class="grid grid-cols-4 gap-1.5 md:gap-2">
							<button
								id="btn-fold"
								class="action-btn bg-[var(--deco-oxblood-bright)] text-[var(--deco-ivory)]"
							>
								Fold
							</button>
							<button
								id="btn-check"
								class="action-btn bg-[var(--deco-sapphire)] text-[var(--deco-ivory)]"
							>
								Check
							</button>
							<button
								id="btn-call"
								class="action-btn bg-[var(--deco-jade)] text-[var(--deco-ivory)]"
							>
								Call
							</button>
							<button
								id="btn-raise"
								class="action-btn bg-linear-to-r from-[var(--deco-brass-bright)] to-[var(--deco-brass)] text-[var(--deco-obsidian)]"
							>
								Raise
							</button>
						</div>

						<!-- Bet Slider Row -->
						<div class="flex gap-2 items-center px-1">
							<input
								type="range"
								id="bet-slider"
								min="10"
								max="1000"
								step="10"
								value="50"
								class="flex-1 h-2 bg-[var(--deco-obsidian-3)] rounded-lg appearance-none cursor-pointer accent-[var(--deco-brass)]"
							/>
							<span
								id="bet-amount"
								class="text-[var(--deco-brass)] font-bold min-w-[60px] text-right text-sm">$50</span
							>
						</div>

						<!-- Quick Bet Chips Row -->
						<div class="flex justify-center gap-2 md:gap-3">
							<button class="quick-bet-chip hover:scale-110 transition-transform" data-amount="10">
								<PokerChip value={10} color="red" />
							</button>
							<button class="quick-bet-chip hover:scale-110 transition-transform" data-amount="25">
								<PokerChip value={25} color="blue" />
							</button>
							<button class="quick-bet-chip hover:scale-110 transition-transform" data-amount="50">
								<PokerChip value={50} color="green" />
							</button>
							<button class="quick-bet-chip hover:scale-110 transition-transform" data-amount="100">
								<PokerChip value={100} color="black" />
							</button>
						</div>

						<!-- Current Bet Display -->
						<div class="text-center text-sm text-[var(--deco-brass)]">
							Your Bet: <span id="current-bet" class="font-semibold">$0</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Game Controls - Simplified (main controls now in table) -->
		<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-5 border border-[var(--deco-line)]">
			<!-- Deal Button + Game Status -->
			<div class="flex flex-col md:flex-row md:items-center gap-4 mb-5">
				<button
					id="btn-deal"
					class="btn-gold py-3 px-8 rounded-lg font-bold text-lg md:w-auto w-full"
				>
					DEAL NEW HAND
				</button>
				<div
					class="flex-1 p-3 bg-[var(--deco-obsidian-2)] rounded-lg border border-[var(--deco-line)]"
				>
					<div class="text-xs text-[var(--deco-muted)] mb-0.5">Game Status</div>
					<div id="game-status" class="text-base font-semibold text-[var(--deco-brass)]">
						Click "DEAL NEW HAND" to start
					</div>
				</div>
			</div>

			<div class="mt-6 p-4 bg-[var(--deco-obsidian-2)] rounded-lg border border-[var(--deco-line)]">
				<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<div class="text-sm text-[var(--deco-muted)] mb-1">AI Rival</div>
						<div id="ai-rival-status" class="text-sm text-[var(--deco-ivory-dim)]">
							{
								gameSession.isGuest
									? 'Sign in to use profile-backed AI rivals.'
									: 'Loading rival settings…'
							}
						</div>
					</div>
					<button
						id="btn-ai-move"
						disabled={gameSession.isGuest}
						class="inline-flex items-center justify-center gap-2 rounded-lg bg-linear-to-r from-[var(--deco-sapphire)] to-[var(--deco-emerald)] px-4 py-2 text-sm font-semibold text-[var(--deco-ivory)] transition disabled:cursor-not-allowed disabled:opacity-60"
					>
						Ask AI Rival
					</button>
				</div>
				<p class="mt-3 text-xs text-[var(--deco-muted)]">
					{
						gameSession.isGuest
							? 'Sign in to configure profile-backed Gemini or OpenAI rivals.'
							: 'Configure API keys in your'
					}
					{
						!gameSession.isGuest && (
							<>
								{' '}
								<a href="/profile" class="text-[var(--deco-brass)] hover:underline">
									profile settings
								</a>{' '}
								to enable Gemini or OpenAI rivals.
							</>
						)
					}
				</p>
			</div>

			<!-- Game Settings -->
			<div class="mt-6 p-4 bg-[var(--deco-obsidian-2)] rounded-lg border border-[var(--deco-line)]">
				<div class="flex items-center justify-between mb-3">
					<div class="text-sm text-[var(--deco-muted)]">Game Settings</div>
					<button
						id="btn-toggle-settings"
						class="text-xs bg-[var(--deco-obsidian-3)] hover:bg-[var(--deco-line)] text-[var(--deco-ivory-dim)] px-3 py-1 rounded transition"
					>
						⚙️ Configure
					</button>
				</div>

				<!-- Collapsible Settings Panel -->
				<div id="settings-panel" class="hidden mt-4 space-y-4">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						<!-- Starting Chips -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Starting Chips</label>
							<input
								type="number"
								id="setting-starting-chips"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
								min="100"
								max="10000"
								step="100"
							/>
						</div>

						<!-- Small Blind -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Small Blind</label>
							<input
								type="number"
								id="setting-small-blind"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
								min="1"
								max="100"
								step="1"
							/>
						</div>

						<!-- Big Blind -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Big Blind</label>
							<input
								type="number"
								id="setting-big-blind"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
								min="2"
								max="200"
								step="1"
							/>
						</div>

						<!-- AI Speed -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">AI Speed</label>
							<select
								id="setting-ai-speed"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
							>
								<option value="slow">Slow (1.5-2.5s)</option>
								<option value="normal">Normal (0.8-1.5s)</option>
								<option value="fast">Fast (0.3-0.6s)</option>
							</select>
						</div>

						<!-- AI Player 2 Difficulty -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Player 2 Difficulty</label>
							<select
								id="setting-ai-difficulty-1"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
							>
								<option value="easy">Easy</option>
								<option value="medium">Medium</option>
								<option value="hard">Hard</option>
							</select>
						</div>

						<!-- AI Player 3 Difficulty -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Player 3 Difficulty</label>
							<select
								id="setting-ai-difficulty-2"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
							>
								<option value="easy">Easy</option>
								<option value="medium">Medium</option>
								<option value="hard">Hard</option>
							</select>
						</div>

						<!-- AI Player 2 Personality -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Player 2 Style</label>
							<select
								id="setting-ai-personality-1"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
							>
								<option value="tight-aggressive">Tight-Aggressive</option>
								<option value="loose-aggressive">Loose-Aggressive</option>
								<option value="tight-passive">Tight-Passive</option>
								<option value="loose-passive">Loose-Passive</option>
							</select>
						</div>

						<!-- AI Player 3 Personality -->
						<div>
							<label class="block text-xs text-[var(--deco-muted)] mb-1">Player 3 Style</label>
							<select
								id="setting-ai-personality-2"
								class="w-full bg-[var(--deco-obsidian-2)] text-[var(--deco-ivory)] px-3 py-2 rounded border border-[var(--deco-line)] focus:border-[var(--deco-brass)] focus:outline-none"
							>
								<option value="tight-aggressive">Tight-Aggressive</option>
								<option value="loose-aggressive">Loose-Aggressive</option>
								<option value="tight-passive">Tight-Passive</option>
								<option value="loose-passive">Loose-Passive</option>
							</select>
						</div>
					</div>

					<!-- LLM AI Toggle -->
					<div class="p-4 bg-[var(--deco-obsidian-2)] rounded-lg border border-[var(--deco-line)]">
						<div class="flex items-center gap-3">
							<input
								type="checkbox"
								id="setting-use-llm-ai"
								class="w-5 h-5 bg-[var(--deco-obsidian-2)] border-[var(--deco-line)] rounded text-[var(--deco-brass)] focus:ring-2 focus:ring-[var(--deco-brass)]"
							/>
							<label for="setting-use-llm-ai" class="flex-1">
								<div class="text-sm text-[var(--deco-ivory)] font-semibold">
									Use LLM-Powered AI Opponents
								</div>
								<div class="text-xs text-[var(--deco-muted)] mt-1">
									Enable OpenAI/Gemini for smarter, more human-like AI play. Requires API key
									configured in profile.
								</div>
							</label>
						</div>
					</div>

					<!-- Action Buttons -->
					<div class="flex gap-2 pt-2">
						<button
							id="btn-save-settings"
							class="flex-1 bg-[var(--deco-brass)] hover:bg-[var(--deco-brass-bright)] text-[var(--deco-obsidian)] px-4 py-2 rounded font-semibold transition"
						>
							Save Settings
						</button>
						<button
							id="btn-reset-settings"
							class="bg-[var(--deco-obsidian-3)] hover:bg-[var(--deco-line)] text-[var(--deco-ivory-dim)] px-4 py-2 rounded transition"
						>
							Reset
						</button>
					</div>

					<p class="text-xs text-[var(--deco-muted)]">
						⚠️ Settings apply to new hands only. Start a new hand after saving.
					</p>
				</div>
			</div>
		</div>

		<!-- Game Info -->
		<div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
			<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-6 border border-[var(--deco-line)]">
				<h3 class="text-xl font-bold text-[var(--deco-brass)] mb-4">🎯 Game Rules</h3>
				<ul class="space-y-2 text-sm text-[var(--deco-ivory-dim)]">
					<li>• Each player gets 2 hole cards</li>
					<li>• 5 community cards revealed in stages</li>
					<li>• Make the best 5-card hand</li>
					<li>• Highest hand wins the pot</li>
				</ul>
			</div>

			<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-6 border border-[var(--deco-line)]">
				<h3 class="text-xl font-bold text-[var(--deco-brass)] mb-4">🏆 Hand Rankings</h3>
				<ul class="space-y-2 text-sm text-[var(--deco-ivory-dim)]">
					<li>• Royal Flush</li>
					<li>• Straight Flush</li>
					<li>• Four of a Kind</li>
					<li>• Full House</li>
					<li>• Flush</li>
				</ul>
			</div>

			<div class="bg-[var(--deco-obsidian-2)] rounded-xl p-6 border border-[var(--deco-line)]">
				<h3 class="text-xl font-bold text-[var(--deco-brass)] mb-4">💰 Betting</h3>
				<ul class="space-y-2 text-sm text-[var(--deco-ivory-dim)]">
					<li>• Minimum bet: $10</li>
					<li>• Maximum bet: $1,000</li>
					<li>• Fold to quit round</li>
					<li>• Check to pass</li>
				</ul>
			</div>
		</div>
	</div>
</CasinoLayout>

<script>
	// Poker game logic
	import { PokerGame } from '../../lib/poker/PokerGame';

	// Initialize game when DOM is loaded
	if (typeof window !== 'undefined') {
		new PokerGame();
	}
</script>
